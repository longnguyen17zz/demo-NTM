          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <p className=\"text-xs text-slate-400 leading-relaxed font-medium\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              Nh\341\273\257ng v\303\271ng thu\341\273\231c bi\303\252n gi\341\273\233i h\341\272\243i \304\221\341\272\243o c\303\263 ng\303\242n s\303\241ch l\341\273\217ng. \304\220\306\260\341\273\243c quy\341\273\201n th\341\273\245 h\306\260\341\273\237ng qu\341\273\271 tr\341\273\243 c\341\272\245p \304\221i\341\273\201u h\303\262a t\341\273\253 kho Qu\341\273\221c gia \304\221\341\273\203 \304\221\341\272\241t chu\341\272\251n s\341\273\221 li\341\273\207u c\306\241 b\341\272\243n nhanh nh\341\272\245t."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            </p>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
