          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  { id: \"c3\", code: \"TC-03\", title: \"Th\341\273\247y l\341\273\243i v\303\240 ph\303\262ng ch\341\273\221ng thi\303\252n tai n\303\242ng cao\", description: \"Di\341\273\207n t\303\255ch \304\221\341\272\245t n\303\264ng nghi\341\273\207p \304\221\306\260\341\273\243c t\306\260\341\273\233i ti\303\252u ch\341\273\247 \304\221\341\273\231ng.\", indicator: \"Th\341\273\247y l\341\273\243i ch\341\273\247 \304\221\341\273\231ng tr\303\252n 80%\", weight: \"8%\" },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  { id: \"c4\", code: \"TC-04\", title: \"\304\220i\341\273\207n v\303\240 c\306\241 s\341\273\237 cung \341\273\251ng \304\221i\341\273\207n an to\303\240n\", description: \"H\341\273\207 th\341\273\221ng \304\221i\341\273\207n \304\221\341\272\241t chu\341\272\251n k\341\273\271 thu\341\272\255t, c\341\272\245p \304\221i\341\273\207n li\303\252n t\341\273\245c an to\303\240n.\", indicator: \"T\341\273\267 l\341\273\207 h\341\273\231 an to\303\240n \304\221i\341\273\207n \304\221\341\272\241t tr\303\252n 98%\", weight: \"5%\" },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  { id: \"c5\", code: \"TC-05\", title: \"Tr\306\260\341\273\235ng h\341\273\215c v\303\240 v\341\272\255t ch\341\272\245t gi\303\241o d\341\273\245c qu\341\273\221c gia\", description: \"C\303\241c c\341\272\245p h\341\273\215c c\303\263 c\306\241 s\341\273\237 \304\221\341\272\241t chu\341\272\251n qu\341\273\221c gia theo quy \304\221\341\273\213nh.\", indicator: \"C\306\241 s\341\273\237 d\341\272\241y h\341\273\215c \304\221\341\272\241t chu\341\272\251n tr\303\252n 75%\", weight: \"12%\" },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
