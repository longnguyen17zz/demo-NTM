          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    id: 5,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    title: \"Ti\303\252u ch\303\255 5: Gi\303\241o d\341\273\245c & \304\220\303\240o t\341\272\241o ngh\341\273\201\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    description: \"Nh\303\240 tr\306\260\341\273\235ng c\303\241c c\341\272\245p c\303\263 c\306\241 s\341\273\237 v\341\272\255t ch\341\272\245t v\303\240 thi\341\272\277t b\341\273\213 d\341\272\241y h\341\273\215c \304\221\341\272\241t chu\341\272\251n qu\341\273\221c gia. \304\220\341\272\241t chu\341\272\251n x\303\263a m\303\271 ch\341\273\257 v\303\240 ph\341\273\225 c\341\272\255p gi\303\241o d\341\273\245c c\341\272\245p trung h\341\273\215c c\306\241 s\341\273\237.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    indicator: \"T\341\273\267 l\341\273\207 h\341\273\215c sinh t\341\273\221t nghi\341\273\207p THCS ti\341\272\277p t\341\273\245c \304\221i h\341\273\215c trung h\341\273\215c ho\341\272\267c h\341\273\215c ngh\341\273\201 t\341\273\221i thi\341\273\203u \304\221\341\272\241t 75%.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    weight: \"12%\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    id: 6,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    title: \"Ti\303\252u ch\303\255 6: C\306\241 s\341\273\237 v\341\272\255t ch\341\272\245t V\304\203n h\303\263a\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    description: \"X\303\243 c\303\263 nh\303\240 v\304\203n h\303\263a ho\341\272\267c h\341\273\231i tr\306\260\341\273\235ng \304\221a n\304\203ng c\303\263 quy m\303\264 ch\341\273\227 ng\341\273\223i \304\221\341\272\241t chu\341\272\251n, c\303\263 s\303\242n th\341\273\203 thao ph\341\273\245c v\341\273\245 c\341\273\231ng \304\221\341\273\223ng.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    indicator: \"T\341\273\267 l\341\273\207 th\303\264n, b\341\272\243n c\303\263 khu th\341\273\203 thao, nh\303\240 v\304\203n h\303\263a \304\221\341\272\241t chu\341\272\251n t\341\273\221i thi\341\273\203u t\341\273\253 70% tr\341\273\237 l\303\252n.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    weight: \"5%\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    id: 7,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    title: \"Ti\303\252u ch\303\255 7: C\306\241 s\341\273\237 h\341\272\241 t\341\272\247ng th\306\260\306\241ng m\341\272\241i n\303\264ng th\303\264n\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    description: \"X\303\243 c\303\263 ch\341\273\243 n\303\264ng th\303\264n ho\341\272\267c si\303\252u th\341\273\213 mini x\303\242y d\341\273\261ng \304\221\303\272ng quy chu\341\272\251n qu\341\273\221c gia, ban qu\341\272\243n l\303\275 ho\341\272\241t \304\221\341\273\231ng hi\341\273\207u qu\341\272\243.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    indicator: \"C\303\263 khu v\341\273\261c v\341\273\207 sinh c\303\264ng c\341\273\231ng, \304\221\341\272\243m b\341\272\243o v\341\273\207 sinh an to\303\240n th\341\273\261c ph\341\272\251m.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    weight: \"5%\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
