        }
        lines {
          text: "    id: 8,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    title: \"Ti\303\252u ch\303\255 8: Th\303\264ng tin v\303\240 Truy\341\273\201n th\303\264ng\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    description: \"X\303\243 c\303\263 \304\221i\341\273\203m ph\341\273\245c v\341\273\245 b\306\260u ch\303\255nh vi\341\273\205n th\303\264ng c\303\263 Internet t\341\273\221c \304\221\341\273\231 cao. C\303\263 \304\221\303\240i truy\341\273\201n thanh ph\303\241t thanh \304\221\341\272\277n to\303\240n b\341\273\231 c\303\241c khu d\303\242n c\306\260.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    indicator: \"C\303\263 \341\273\251ng d\341\273\245ng c\303\264ng ngh\341\273\207 th\303\264ng tin trong gi\341\272\243i quy\341\272\277t d\341\273\213ch v\341\273\245 c\303\264ng c\341\272\245p x\303\243.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    weight: \"10%\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    id: 9,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    title: \"Ti\303\252u ch\303\255 9: Nh\303\240 \341\273\237 d\303\242n c\306\260 n\303\264ng th\303\264n\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    description: \"Kh\303\264ng c\303\262n nh\303\240 t\341\272\241m, nh\303\240 d\341\273\231t n\303\241t tr\303\252n \304\221\341\273\213a b\303\240n x\303\243. T\341\273\267 l\341\273\207 h\341\273\231 gia \304\221\303\254nh c\303\263 nh\303\240 \341\273\237 ki\303\252n c\341\273\221 ho\341\272\267c b\303\241n ki\303\252n c\341\273\221 \304\221\341\272\241t t\341\273\253 90% tr\341\273\237 l\303\252n.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    indicator: \"Di\341\273\207n t\303\255ch nh\303\240 \341\273\237 b\303\254nh qu\303\242n \304\221\341\272\247u ng\306\260\341\273\235i \304\221\341\272\241t m\341\273\251c t\341\273\221i thi\341\273\203u 15-20 m2/ng\306\260\341\273\235i.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    weight: \"15%\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    id: 10,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    title: \"Ti\303\252u ch\303\255 10: Thu nh\341\272\255p & Ph\303\241t tri\341\273\203n kinh t\341\272\277\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    description: \"M\341\273\251c thu nh\341\272\255p b\303\254nh qu\303\242n \304\221\341\272\247u ng\306\260\341\273\235i c\341\273\247a x\303\243 \304\221\341\272\241t t\341\273\221i thi\341\273\203u t\341\273\253 53 tri\341\273\207u \304\221\341\273\223ng/ng\306\260\341\273\235i/n\304\203m tr\341\273\237 l\303\252n (\304\221i\341\273\201u ch\341\273\211nh t\304\203ng theo t\341\273\253ng n\304\203m v\303\240 t\341\273\253ng v\303\271ng c\341\273\245 th\341\273\203).\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    indicator: \"C\303\263 c\303\241c chu\341\273\227i m\303\264 h\303\254nh li\303\252n k\341\272\277t s\341\272\243n xu\341\272\245t n\303\264ng nghi\341\273\207p \341\273\251ng d\341\273\245ng c\303\264ng ngh\341\273\207 cao.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    weight: \"15%\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
