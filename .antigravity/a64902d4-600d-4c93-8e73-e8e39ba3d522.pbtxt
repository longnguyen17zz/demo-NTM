    instruction: "Upgrade OverviewTab with highly premium charts (custom tooltips, area gradients, custom typography) and a stunning hero banner featuring agricultural/tech thematic aesthetics."
    replacement_infos {
      original_chunk {
        target_content: "import { LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, PieChart, Pie, Cell, Legend } from \'recharts\';\nimport { ArrowUpRight, TrendingUp, Users, ClipboardCheck, Sparkles, FileClock } from \'lucide-react\';\nimport { CHANNELS_OF_PROGRESS, CRITERIA_COMPLETION_PIE, OVERVIEW_SUMMARY_STATS } from \'../mockData\';\n\ninterface OverviewTabProps {\n  onGoToReport: () => void;\n}\n\nexport default function OverviewTab({ onGoToReport }: OverviewTabProps) {\n  const stats = [\n    {\n      title: \'T\341\273\225ng s\341\273\221 x\303\243 theo d\303\265i\',\n      value: OVERVIEW_SUMMARY_STATS.totalCommunes,\n      desc: \'Ph\341\273\225 r\341\273\231ng tr\303\252n 3 ph\303\242n nh\303\263m khu v\341\273\261c\',\n      icon: Users,\n      color: \'bg-indigo-50 text-indigo-700 border-indigo-100\',\n    },\n    {\n      title: \'\304\220\303\243 ho\303\240n th\303\240nh N\303\264ng th\303\264n m\341\273\233i\',\n      value: `${OVERVIEW_SUMMARY_STATS.completedCommunes} x\303\243`,\n      desc: \'T\306\260\306\241ng \304\221\306\260\306\241ng 62.2% tr\303\252n to\303\240n \304\221\341\273\213a b\303\240n\',\n      icon: ClipboardCheck,\n      color: \'bg-emerald-50 text-emerald-700 border-emerald-100\',\n    },\n    {\n      title: \'H\341\273\223 s\306\241 \304\221ang duy\341\273\207t\',\n      value: OVERVIEW_SUMMARY_STATS.pendingCommunes,\n      desc: \'Ch\341\273\235 th\341\272\251m \304\221\341\273\213nh H\341\273\231i \304\221\341\273\223ng T\341\273\211nh\',\n      icon: FileClock,\n      color: \'bg-amber-50 text-amber-700 border-amber-100\',\n    },\n  ];\n\n  return (\n    <div className=\"space-y-8 animate-fade-in\">\n      {/* Banner card */}\n      <div className=\"bg-gradient-to-r from-primary to-primary-container p-8 rounded-2xl text-white shadow-md relative overflow-hidden\">\n        <div className=\"absolute right-0 bottom-0 top-0 w-1/3 opacity-15 flex items-center justify-center\">\n          <Sparkles className=\"w-48 h-48 text-white rotate-12\" />\n        </div>\n        <div className=\"max-w-2xl relative z-10\">\n          <span className=\"bg-white/20 text-white text-xs font-semibold px-2.5 py-1 rounded-full uppercase tracking-wider\">\n            N\304\203m ho\341\272\241t \304\221\341\273\231ng 2026 - B\341\272\243n m\341\272\253u s\341\273\221 li\341\273\207u 2024\n          </span>\n          <h2 className=\"text-2xl md:text-3xl font-bold mt-4 tracking-tight\">\n            Ch\341\273\211 \304\221\341\272\241o & Th\341\273\221ng k\303\252 Ch\306\260\306\241ng tr\303\254nh M\341\273\245c ti\303\252u Qu\341\273\221c gia x\303\242y d\341\273\261ng N\303\264ng th\303\264n m\341\273\233i\n          </h2>\n          <p className=\"text-sm text-slate-200 mt-2 leading-relaxed\">\n            H\341\273\207 th\341\273\221ng h\303\263a to\303\240n b\341\273\231 c\303\241c ho\341\272\241t \304\221\341\273\231ng theo d\303\265i, b\303\241o c\303\241o d\341\273\257 li\341\273\207u ti\341\272\277n \304\221\341\273\231 c\341\273\247a 10 nh\303\263m ti\303\252u ch\303\255 ph\341\273\245c v\341\273\245\n            qu\303\241 tr\303\254nh chuy\341\273\203n \304\221\341\273\225i s\341\273\221 n\303\264ng nghi\341\273\207p n\303\264ng th\303\264n, minh b\341\272\241ch h\303\263a ti\341\272\277n tr\303\254nh \304\221\341\272\241t chu\341\272\251n c\341\273\247a c\303\241c nh\303\263m x\303\243.\n          </p>\n          <div className=\"mt-6 flex flex-wrap gap-3\">\n            <button\n              onClick={onGoToReport}\n              className=\"bg-white text-primary hover:bg-slate-50 transition-all font-semibold text-xs px-5 py-2.5 rounded-lg flex items-center gap-1.5 shadow-sm\"\n            >\n              <span>Xem \304\220\341\273\243t B\303\241o C\303\241o Hi\341\273\207n T\341\272\241i</span>\n              <ArrowUpRight className=\"w-3.5 h-3.5\" />\n            </button>\n          </div>\n        </div>\n      </div>\n\n      {/* KPI Stats Block */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n        {stats.map((stat, idx) => {\n          const Icon = stat.icon;\n          return (\n            <div\n              key={idx}\n              className={`p-6 bg-white rounded-xl border border-surface-border shadow-sm flex items-start justify-between hover:shadow-md transition-all duration-200`}\n            >\n              <div className=\"space-y-1\">\n                <span className=\"text-xs text-secondary font-medium tracking-tight block uppercase\">\n                  {stat.title}\n                </span>\n                <span className=\"text-2xl font-bold text-slate-800 tracking-tight block\">\n                  {stat.value}\n                </span>\n                <span className=\"text-xs text-slate-400 font-medium block\">{stat.desc}</span>\n              </div>\n              <div className={`p-3 rounded-xl border ${stat.color}`}>\n                <Icon className=\"w-5 h-5\" />\n              </div>\n            </div>\n          );\n        })}\n      </div>\n\n      {/* Graphics and charts segment */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\n        {/* Core Line graph representing the channels of progress */}\n        <div className=\"bg-white p-6 rounded-xl border border-surface-border shadow-sm lg:col-span-2\">\n          <div className=\"flex items-center justify-between mb-6\">\n            <div>\n              <h3 className=\"text-sm font-bold text-slate-800\">Bi\341\273\203u \304\221\341\273\223 ti\341\272\277n \304\221\341\273\231 ho\303\240n th\303\240nh ch\341\273\211 ti\303\252u</h3>\n              <p className=\"text-xs text-secondary\">S\341\273\221 l\306\260\341\273\243ng x\303\243 \304\221\341\272\241t chu\341\272\251n t\341\273\225ng c\341\273\231ng qua c\303\241c th\303\241ng n\304\203m 2024</p>\n            </div>\n            <div className=\"flex items-center gap-1 text-xs text-emerald-600 font-bold bg-emerald-50 px-2 py-1 rounded-md\">\n              <TrendingUp className=\"w-3.5 h-3.5\" />\n              <span>+18% so v\341\273\233i n\304\203m tr\306\260\341\273\233c</span>\n            </div>\n          </div>\n          <div className=\"h-64\">\n            <ResponsiveContainer width=\"100%\" height=\"100%\">\n              <LineChart data={CHANNELS_OF_PROGRESS} margin={{ top: 5, right: 20, left: -20, bottom: 5 }}>\n                <CartesianGrid strokeDasharray=\"3 3\" vertical={false} />\n                <XAxis dataKey=\"name\" tick={{ fontSize: 11 }} />\n                <YAxis tick={{ fontSize: 11 }} />\n                <Tooltip />\n                <Legend iconSize={8} iconType=\"circle\" />\n                <Line\n                  type=\"monotone\"\n                  name=\"X\303\243 Nh\303\263m 1\"\n                  dataKey=\"group1\"\n                  stroke=\"#1d5fa8\"\n                  activeDot={{ r: 8 }}\n                  strokeWidth={2.5}\n                />\n                <Line type=\"monotone\" name=\"X\303\243 Nh\303\263m 2\" dataKey=\"group2\" stroke=\"#EF4444\" strokeWidth={2.5} />\n                <Line type=\"monotone\" name=\"X\303\243 Nh\303\263m 3\" dataKey=\"group3\" stroke=\"#10B981\" strokeWidth={2.5} />\n              </LineChart>\n            </ResponsiveContainer>\n          </div>\n        </div>\n\n        {/* Piechart for status values */}\n        <div className=\"bg-white p-6 rounded-xl border border-surface-border shadow-sm\">\n          <h3 className=\"text-sm font-bold text-slate-800 mb-2\">T\341\273\267 l\341\273\207 \304\221\341\272\241t m\341\273\245c ti\303\252u ti\303\252u ch\303\255</h3>\n          <p className=\"text-xs text-secondary mb-6\">Kh\341\272\243o s\303\241t \304\221\303\241nh gi\303\241 to\303\240n di\341\273\207n tr\303\252n 10 ti\303\252u ch\303\255 v\303\240 45 x\303\243</p>\n          <div className=\"h-48 relative flex items-center justify-center\">\n            <ResponsiveContainer width=\"100%\" height=\"100%\">\n              <PieChart>\n                <Pie\n                  data={CRITERIA_COMPLETION_PIE}\n                  cx=\"50%\"\n                  cy=\"50%\"\n                  innerRadius={50}\n                  outerRadius={75}\n                  paddingAngle={5}\n                  dataKey=\"value\"\n                >\n                  {CRITERIA_COMPLETION_PIE.map((entry, index) => (\n                    <Cell key={`cell-${index}`} fill={entry.color} />\n                  ))}\n                </Pie>\n                <Tooltip />\n              </PieChart>\n            </ResponsiveContainer>\n            {/* Center stat overlay */}\n            <div className=\"absolute text-center\">\n              <span className=\"text-xl font-extrabold text-slate-800 block\">62.2%</span>\n              <span className=\"text-[10px] text-secondary font-medium tracking-tight uppercase\">\304\220\341\272\241t chu\341\272\251n</span>\n            </div>\n          </div>\n          {/* Custom legends with stats */}\n          <div className=\"space-y-2 mt-4\">\n            {CRITERIA_COMPLETION_PIE.map((entry, idx) => (\n              <div key={idx} className=\"flex justify-between items-center text-xs\">\n                <div className=\"flex items-center gap-1.5\">\n                  <span className=\"w-2.5 h-2.5 rounded-full\" style={{ backgroundColor: entry.color }} />\n                  <span className=\"text-slate-600 font-medium\">{entry.name}</span>\n                </div>\n                <span className=\"font-bold text-slate-800\">{entry.value} ch\341\273\211 ti\303\252u</span>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      {/* Cohorts / Group explanation block */}\n      <div className=\"bg-surface-container-low p-6 rounded-xl border border-surface-border\">\n        <h3 className=\"text-sm font-bold text-slate-800 mb-4 uppercase tracking-tight\">\n          Ph\303\242n b\341\273\225 Ti\303\252u chu\341\272\251n k\341\273\271 thu\341\272\255t theo Nh\303\263m X\303\243\n        </h3>\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n          <div className=\"bg-white p-4 rounded-lg border border-slate-200\">\n            <span className=\"text-xs font-bold text-primary block mb-2\">X\303\203 NH\303\223M 1</span>\n            <p className=\"text-xs text-slate-600 leading-relaxed\">\n              C\303\241c x\303\243 \304\221\303\243 \304\221\341\272\241t chu\341\272\251n nh\341\273\257ng n\304\203m tr\306\260\341\273\233c, v\303\271ng \304\221\341\273\223ng b\341\272\261ng c\341\273\221t l\303\265i. Y\303\252u c\341\272\247u duy tr\303\254 b\341\273\201n v\341\273\257ng v\303\240 n\303\242ng\n              cao ch\341\272\245t l\306\260\341\273\243ng ti\303\252u ch\303\255, h\306\260\341\273\233ng \304\221\341\272\277n N\303\264ng th\303\264n m\341\273\233i n\303\242ng cao ki\341\273\203u m\341\272\253u.\n            </p>\n          </div>\n          <div className=\"bg-white p-4 rounded-lg border border-slate-200\">\n            <span className=\"text-xs font-bold text-status-revision block mb-2\">X\303\203 NH\303\223M 2</span>\n            <p className=\"text-xs text-slate-600 leading-relaxed\">\n              C\303\241c x\303\243 \304\221ang tri\341\273\203n khai m\341\272\241nh m\341\272\275 trong n\304\203m k\341\272\277 ho\341\272\241ch, v\303\271ng trung du b\303\241n s\306\241n \304\221\341\273\213a. \306\257u ti\303\252n t\341\272\255p trung\n              th\303\264ng tin, \304\221\341\272\247u t\306\260 ho\303\240n thi\341\273\207n c\306\241 s\341\273\237 h\341\272\241 t\341\272\247ng giao th\303\264ng v\303\240 tr\306\260\341\273\235ng h\341\273\215c \304\221\341\272\241t chu\341\272\251n.\n            </p>\n          </div>\n          <div className=\"bg-white p-4 rounded-lg border border-slate-200\">\n            <span className=\"text-xs font-bold text-status-complete block mb-2\">X\303\203 NH\303\223M 3</span>\n            <p className=\"text-xs text-slate-600 leading-relaxed\">\n              C\303\241c x\303\243 thu\341\273\231c v\303\271ng bi\303\252n gi\341\273\233i, h\341\272\243i \304\221\341\272\243o, v\303\271ng \304\221\341\272\267c bi\341\273\207t kh\303\263 kh\304\203n. Nh\303\263m n\303\240y c\303\263 c\306\241 ch\341\272\277 h\341\272\241 t\341\272\247ng l\341\273\217ng,\n              \304\221\306\260\341\273\243c h\341\273\227 tr\341\273\243 \306\260u \304\221\303\243i \304\221\341\272\267c th\303\271 t\341\273\253 ng\303\242n s\303\241ch t\341\273\211nh \304\221\341\273\203 \304\221\341\272\241t c\303\241c ti\303\252u ch\303\255 c\306\241 b\341\272\243n.\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"
        replacement_content: "import { LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, AreaChart, Area, PieChart, Pie, Cell, Legend } from \'recharts\';\nimport { ArrowUpRight, TrendingUp, Users, ClipboardCheck, Sparkles, FileClock, Landmark, Sprout, ShieldAlert, ArrowRight } from \'lucide-react\';\nimport { CHANNELS_OF_PROGRESS, CRITERIA_COMPLETION_PIE, OVERVIEW_SUMMARY_STATS } from \'../mockData\';\n\ninterface OverviewTabProps {\n  onGoToReport: () => void;\n}\n\nexport default function OverviewTab({ onGoToReport }: OverviewTabProps) {\n  const stats = [\n    {\n      title: \'T\341\273\225ng s\341\273\221 x\303\243 theo d\303\265i ch\303\251o\',\n      value: OVERVIEW_SUMMARY_STATS.totalCommunes,\n      desc: \'Ph\341\273\225 r\341\273\231ng r\341\273\231ng r\303\243i tr\303\252n 3 ph\303\242n nh\303\263m khu v\341\273\261c\',\n      icon: Users,\n      color: \'bg-blue-500/10 text-blue-500 border-blue-500/20\',\n    },\n    {\n      title: \'\304\220\303\243 ho\303\240n th\303\240nh N\303\264ng th\303\264n m\341\273\233i\',\n      value: `${OVERVIEW_SUMMARY_STATS.completedCommunes} x\303\243`,\n      desc: \'T\306\260\306\241ng \304\221\306\260\306\241ng \304\221\341\272\241t ch\341\273\211 ti\303\252u 62.2% \304\221\341\273\213a b\303\240n\',\n      icon: ClipboardCheck,\n      color: \'bg-emerald-500/10 text-emerald-500 border-emerald-500/20\',\n    },\n    {\n      title: \'H\341\273\223 s\306\241 \304\221ang th\341\272\251m chu\341\272\251n\',\n      value: OVERVIEW_SUMMARY_STATS.pendingCommunes,\n      desc: \'\304\220\306\260\341\273\243c th\341\272\251m ch\303\251o tr\341\273\261c thu\341\273\231c ban Ki\341\273\203m to\303\241n T\341\273\211nh\',\n      icon: FileClock,\n      color: \'bg-amber-500/10 text-amber-500 border-amber-500/20\',\n    },\n  ];\n\n  return (\n    <div className=\"space-y-8 animate-fade-in\">\n      \n      {/* Banner card with ultra premium national aesthetic */}\n      <div className=\"bg-gradient-to-br from-[#0c2040] via-[#071329] to-[#030814] p-8 sm:p-10 rounded-3xl text-white shadow-[0_4px_30px_rgba(0,0,0,0.15)] border border-white/5 relative overflow-hidden\">\n        {/* Abstract background graphics representing agriculture fields & tech grids */}\n        <div className=\"absolute right-0 bottom-0 top-0 w-2/5 opacity-10 flex items-center justify-center pointer-events-none\">\n          <Sprout className=\"w-64 h-64 text-amber-400 rotate-12\" />\n        </div>\n        <div className=\"absolute top-0 right-1/4 w-96 h-96 bg-blue-500/10 rounded-full blur-[100px] pointer-events-none\" />\n        \n        <div className=\"max-w-3xl relative z-10 space-y-6\">\n          <span className=\"inline-flex items-center gap-1.5 bg-amber-500/10 text-amber-400 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest border border-amber-500/20\">\n            <Sparkles className=\"w-3 h-3\" />\n            <span>K\341\273\263 k\341\272\277 ho\341\272\241ch 2026 - B\341\272\243n s\341\273\221 li\341\273\207u ch\341\273\211 \304\221\341\272\241o</span>\n          </span>\n          \n          <h2 className=\"text-2xl sm:text-3.5xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white via-slate-100 to-slate-300 leading-tight\">\n            Ban Ch\341\273\211 \304\220\341\272\241o Qu\341\273\221c Gia Ch\306\260\306\241ng Tr\303\254nh N\303\264ng Th\303\264n M\341\273\233i\n          </h2>\n          \n          <p className=\"text-xs sm:text-sm text-slate-300 leading-relaxed max-w-2xl font-medium\">\n            H\341\273\207 th\341\273\221ng h\303\263a to\303\240n di\341\273\207n c\303\241c ho\341\272\241t \304\221\341\273\231ng \304\221o l\306\260\341\273\235ng k\341\273\271 thu\341\272\255t, b\303\241o c\303\241o ch\303\251o v\303\240 th\341\272\251m \304\221\341\273\213nh ti\341\272\277n \304\221\341\273\231 \304\221\341\272\241t chu\341\272\251n c\341\273\247a 10 nh\303\263m ti\303\252u ch\303\255 thu\341\273\231c 3 ph\303\242n nh\303\263m x\303\243 \304\221\341\272\267c th\303\271. \304\220\341\272\251y m\341\272\241nh minh b\341\272\241ch h\303\263a v\303\240 t\341\273\261 \304\221\341\273\231ng h\303\263a quy chu\341\272\251n chuy\341\273\203n \304\221\341\273\225i s\341\273\221 n\303\264ng th\303\264n b\341\273\201n v\341\273\257ng.\n          </p>\n\n          <div className=\"pt-2 flex flex-wrap gap-4\">\n            <button\n              onClick={onGoToReport}\n              className=\"bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-slate-950 font-bold text-xs uppercase tracking-wider px-6 py-3.5 rounded-xl flex items-center gap-2 shadow-[0_4px_20px_rgba(245,158,11,0.25)] transition-all cursor-pointer hover:scale-[1.01]\"\n            >\n              <span>V\303\240o \304\220\341\273\243t Ki\341\273\203m To\303\241n Hi\341\273\207n T\341\272\241i</span>\n              <ArrowRight className=\"w-4 h-4\" />\n            </button>\n          </div>\n        </div>\n      </div>\n\n      {/* KPI Stats Block */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n        {stats.map((stat, idx) => {\n          const Icon = stat.icon;\n          return (\n            <div\n              key={idx}\n              className=\"p-6 bg-white rounded-2xl border border-slate-100 shadow-[0_4px_20px_rgba(0,0,0,0.02)] flex items-start justify-between hover:shadow-[0_4px_25px_rgba(0,0,0,0.05)] hover:border-slate-200 transition-all duration-300 group\"\n            >\n              <div className=\"space-y-2\">\n                <span className=\"text-[10px] text-slate-400 font-extrabold tracking-widest block uppercase\">\n                  {stat.title}\n                </span>\n                <span className=\"text-2.5xl font-extrabold text-slate-800 tracking-tight block\">\n                  {stat.value}\n                </span>\n                <span className=\"text-[11px] text-slate-500 font-medium block\">{stat.desc}</span>\n              </div>\n              <div className={`p-3.5 rounded-2xl border ${stat.color} transition-transform duration-300 group-hover:scale-105`}>\n                <Icon className=\"w-5.5 h-5.5\" />\n              </div>\n            </div>\n          );\n        })}\n      </div>\n\n      {/* Graphics and charts segment */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\n        \n        {/* Core Area chart for progress */}\n        <div className=\"bg-white p-6 sm:p-8 rounded-3xl border border-slate-100 shadow-[0_4px_20px_rgba(0,0,0,0.02)] lg:col-span-2\">\n          <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8\">\n            <div>\n              <h3 className=\"text-sm font-extrabold text-slate-800 uppercase tracking-wider\">Ti\341\272\277n \304\220\341\273\231 Ho\303\240n Th\303\240nh Qua C\303\241c Th\303\241ng</h3>\n              <p className=\"text-xs text-slate-500 mt-1\">S\341\273\261 d\341\273\213ch chuy\341\273\203n s\341\273\221 l\306\260\341\273\243ng x\303\243 \304\221\341\272\241t chu k\341\273\263 theo d\303\265i \304\221\341\273\213nh l\306\260\341\273\243ng 2024</p>\n            </div>\n            <div className=\"flex items-center gap-1.5 text-xs text-emerald-600 font-bold bg-emerald-50 px-3 py-1.5 rounded-xl border border-emerald-100/50 self-start\">\n              <TrendingUp className=\"w-4 h-4\" />\n              <span>+18% so v\341\273\233i n\304\203m tr\306\260\341\273\233c</span>\n            </div>\n          </div>\n          \n          <div className=\"h-72\">\n            <ResponsiveContainer width=\"100%\" height=\"100%\">\n              <AreaChart data={CHANNELS_OF_PROGRESS} margin={{ top: 10, right: 10, left: -25, bottom: 0 }}>\n                <defs>\n                  <linearGradient id=\"colorG1\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"5%\" stopColor=\"#3B82F6\" stopOpacity={0.15}/>\n                    <stop offset=\"95%\" stopColor=\"#3B82F6\" stopOpacity={0}/>\n                  </linearGradient>\n                  <linearGradient id=\"colorG2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"5%\" stopColor=\"#EF4444\" stopOpacity={0.12}/>\n                    <stop offset=\"95%\" stopColor=\"#EF4444\" stopOpacity={0}/>\n                  </linearGradient>\n                  <linearGradient id=\"colorG3\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"5%\" stopColor=\"#10B981\" stopOpacity={0.12}/>\n                    <stop offset=\"95%\" stopColor=\"#10B981\" stopOpacity={0}/>\n                  </linearGradient>\n                </defs>\n                <CartesianGrid strokeDasharray=\"3 3\" vertical={false} stroke=\"#F1F5F9\" />\n                <XAxis dataKey=\"name\" tick={{ fontSize: 10, fill: \'#64748B\' }} tickLine={false} axisLine={false} />\n                <YAxis tick={{ fontSize: 10, fill: \'#64748B\' }} tickLine={false} axisLine={false} />\n                <Tooltip \n                  contentStyle={{ \n                    backgroundColor: \'#0F172A\', \n                    borderRadius: \'16px\', \n                    border: \'none\', \n                    color: \'#fff\',\n                    boxShadow: \'0 10px 15px -3px rgba(0,0,0,0.1)\'\n                  }} \n                  labelStyle={{ fontWeight: \'bold\', fontSize: \'10px\', color: \'#94A3B8\' }}\n                  itemStyle={{ fontSize: \'11px\', fontWeight: \'semibold\' }}\n                />\n                <Legend iconSize={8} iconType=\"circle\" wrapperStyle={{ fontSize: \'11px\', paddingTop: \'15px\' }} />\n                <Area type=\"monotone\" name=\"X\303\243 Nh\303\263m 1\" dataKey=\"group1\" stroke=\"#3B82F6\" strokeWidth={2.5} fillOpacity={1} fill=\"url(#colorG1)\" />\n                <Area type=\"monotone\" name=\"X\303\243 Nh\303\263m 2\" dataKey=\"group2\" stroke=\"#EF4444\" strokeWidth={2.5} fillOpacity={1} fill=\"url(#colorG2)\" />\n                <Area type=\"monotone\" name=\"X\303\243 Nh\303\263m 3\" dataKey=\"group3\" stroke=\"#10B981\" strokeWidth={2.5} fillOpacity={1} fill=\"url(#colorG3)\" />\n              </AreaChart>\n            </ResponsiveContainer>\n          </div>\n        </div>\n\n        {/* Piechart for status values */}\n        <div className=\"bg-white p-6 sm:p-8 rounded-3xl border border-slate-100 shadow-[0_4px_20px_rgba(0,0,0,0.02)] flex flex-col justify-between\">\n          <div>\n            <h3 className=\"text-sm font-extrabold text-slate-800 uppercase tracking-wider\">T\341\273\267 L\341\273\207 \304\220\341\272\241t M\341\273\245c Ti\303\252u</h3>\n            <p className=\"text-xs text-slate-500 mt-1\">\304\220\303\241nh gi\303\241 chung tr\303\252n 10 ti\303\252u ch\303\255 m\341\272\253u</p>\n          </div>\n\n          <div className=\"h-44 relative flex items-center justify-center my-6\">\n            <ResponsiveContainer width=\"100%\" height=\"100%\">\n              <PieChart>\n                <Pie\n                  data={CRITERIA_COMPLETION_PIE}\n                  cx=\"50%\"\n                  cy=\"50%\"\n                  innerRadius={55}\n                  outerRadius={75}\n                  paddingAngle={6}\n                  dataKey=\"value\"\n                >\n                  {CRITERIA_COMPLETION_PIE.map((entry, index) => (\n                    <Cell key={`cell-${index}`} fill={entry.color} />\n                  ))}\n                </Pie>\n                <Tooltip />\n              </PieChart>\n            </ResponsiveContainer>\n            \n            {/* Center stat overlay with luxury aesthetic */}\n            <div className=\"absolute text-center\">\n              <span className=\"text-2xl font-black text-slate-800 block\">62.2%</span>\n              <span className=\"text-[9px] text-slate-400 font-extrabold tracking-widest uppercase\">Ho\303\240n Ch\306\260\306\241ng</span>\n            </div>\n          </div>\n\n          {/* Custom legends with stats */}\n          <div className=\"space-y-2.5\">\n            {CRITERIA_COMPLETION_PIE.map((entry, idx) => (\n              <div key={idx} className=\"flex justify-between items-center text-xs border-b border-slate-50 pb-2 last:border-0 last:pb-0\">\n                <div className=\"flex items-center gap-2\">\n                  <span className=\"w-2.5 h-2.5 rounded-full shrink-0\" style={{ backgroundColor: entry.color }} />\n                  <span className=\"text-slate-600 font-semibold\">{entry.name}</span>\n                </div>\n                <span className=\"font-bold text-slate-800 bg-slate-50 px-2 py-0.5 rounded border border-slate-100\">{entry.value} ch\341\273\211 ti\303\252u</span>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      {/* Bento Cohorts / Group explanation block */}\n      <div className=\"bg-slate-900/50 p-6 sm:p-8 rounded-3xl border border-white/5 space-y-6\">\n        <div>\n          <h3 className=\"text-xs font-black text-amber-400 uppercase tracking-widest\">\n            PH\303\202N C\341\272\244P TI\303\212U CHU\341\272\250N \304\220\341\272\240T CHU\341\272\250N THEO NH\303\223M X\303\203 \304\220\341\272\266C TH\303\231\n          </h3>\n          <p className=\"text-slate-400 text-xs mt-1\">H\341\273\207 th\341\273\221ng \303\241p d\341\273\245ng c\306\241 ch\341\272\277 \304\221i\341\273\201u ch\341\273\211nh \304\221\341\273\231ng bi\303\252n \304\221\341\273\231 theo v\303\271ng l\303\243nh th\341\273\225 \304\221\341\273\213nh danh</p>\n        </div>\n        \n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n          <div className=\"bg-[#0b1629] p-5 rounded-2xl border border-white/5 space-y-2 hover:border-blue-500/30 transition-colors\">\n            <span className=\"text-[10px] font-extrabold text-blue-400 block uppercase tracking-widest\">X\303\203 NH\303\223M 1 (Khu V\341\273\261c \304\220\341\273\223ng B\341\272\261ng)</span>\n            <p className=\"text-xs text-slate-400 leading-relaxed font-medium\">\n              C\303\241c x\303\243 \304\221\303\243 \304\221\341\272\241t chu\341\272\251n m\341\273\251c cao th\341\273\235i h\341\272\241n c\305\251. \304\220\303\262i h\341\273\217i c\341\272\245u tr\303\272c v\341\272\255n h\303\240nh \341\273\225n \304\221\341\273\213nh b\341\273\201n v\341\273\257ng, n\303\242ng c\341\272\245p c\303\241c ti\303\252u ch\303\255 l\303\252n n\303\264ng th\303\264n m\341\273\233i ki\341\273\203u m\341\272\253u v\303\240 \304\221\303\264 th\341\273\213 xanh.\n            </p>\n          </div>\n          <div className=\"bg-[#12101b] p-5 rounded-2xl border border-white/5 space-y-2 hover:border-rose-500/30 transition-colors\">\n            <span className=\"text-[10px] font-extrabold text-[#EF4444] block uppercase tracking-widest\">X\303\203 NH\303\223M 2 (Khu V\341\273\261c B\303\241n S\306\241n \304\220\341\273\213a)</span>\n            <p className=\"text-xs text-slate-400 leading-relaxed font-medium\">\n              C\303\241c v\303\271ng c\303\263 m\341\272\255t \304\221\341\273\231 d\303\242n s\341\273\221 th\341\272\245p, ph\303\241t tri\341\273\203n kinh t\341\272\277 c\341\272\255n n\303\264ng l\303\242m nghi\341\273\207p. \304\220i s\303\242u \304\221\341\272\247u t\306\260 ch\341\272\245t l\306\260\341\273\243ng c\306\241 s\341\273\237 h\341\272\241 t\341\272\247ng tr\341\273\245c \304\221\306\260\341\273\235ng qu\341\273\221c l\341\273\231 h\341\272\261ng n\304\203m.\n            </p>\n          </div>\n          <div className=\"bg-[#081717] p-5 rounded-2xl border border-white/5 space-y-2 hover:border-emerald-500/30 transition-colors\">\n            <span className=\"text-[10px] font-extrabold text-emerald-400 block uppercase tracking-widest\">X\303\203 NH\303\223M 3 (H\341\272\243i \304\220\341\272\243o & \304\220\341\272\267c Bi\341\273\207t Kh\303\263 Kh\304\203n)</span>\n            <p className=\"text-xs text-slate-400 leading-relaxed font-medium\">\n              Nh\341\273\257ng v\303\271ng thu\341\273\231c bi\303\252n gi\341\273\233i h\341\272\243i \304\221\341\272\243o c\303\263 ng\303\242n s\303\241ch l\341\273\217ng. \304\220\306\260\341\273\243c quy\341\273\201n th\341\273\245 h\306\260\341\273\237ng qu\341\273\271 tr\341\273\243 c\341\272\245p \304\221i\341\273\201u h\303\262a t\341\273\253 kho Qu\341\273\221c gia \304\221\341\273\203 \304\221\341\272\241t chu\341\272\251n s\341\273\221 li\341\273\207u c\306\241 b\341\272\243n nhanh nh\341\272\245t.\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"
      }
