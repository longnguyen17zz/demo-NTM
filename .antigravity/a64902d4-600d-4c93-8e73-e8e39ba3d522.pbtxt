          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    title: \"Ti\303\252u ch\303\255 10: Thu nh\341\272\255p & Ph\303\241t tri\341\273\203n kinh t\341\272\277\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    description: \"M\341\273\251c thu nh\341\272\255p b\303\254nh qu\303\242n \304\221\341\272\247u ng\306\260\341\273\235i c\341\273\247a x\303\243 \304\221\341\272\241t t\341\273\221i thi\341\273\203u t\341\273\253 53 tri\341\273\207u \304\221\341\273\223ng/ng\306\260\341\273\235i/n\304\203m tr\341\273\237 l\303\252n (\304\221i\341\273\201u ch\341\273\211nh t\304\203ng theo t\341\273\253ng n\304\203m v\303\240 t\341\273\253ng v\303\271ng c\341\273\245 th\341\273\203).\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    indicator: \"C\303\263 c\303\241c chu\341\273\227i m\303\264 h\303\254nh li\303\252n k\341\272\277t s\341\272\243n xu\341\272\245t n\303\264ng nghi\341\273\207p \341\273\251ng d\341\273\245ng c\303\264ng ngh\341\273\207 cao.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
