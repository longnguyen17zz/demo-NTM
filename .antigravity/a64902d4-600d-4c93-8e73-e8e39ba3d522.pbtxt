          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "              <div className=\"space-y-1.5\">"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                <span className=\"font-bold text-slate-800 uppercase text-[11px] block text-primary\">3. Quy chu\341\272\251n ch\341\273\257 k\303\275 s\341\273\221 CA qu\341\273\221c gia</span>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                <p>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                  H\341\273\223 s\306\241 g\341\273\255i l\303\252n b\341\273\231 ng\303\240nh trung \306\260\306\241ng b\341\272\257t bu\341\273\231c \304\221\306\260\341\273\243c ch\341\273\251ng th\341\273\261c ph\303\252 chu\341\272\251n th\303\264ng qua h\341\273\207 th\341\273\221ng ch\341\273\251ng th\306\260 s\341\273\221 c\341\273\247a T\341\273\225ng c\341\273\245c B\306\260u \304\221i\341\273\207n ho\341\272\267c ban c\306\241 y\341\272\277u Ch\303\255nh ph\341\273\247. Vi\341\273\207c nh\341\272\255p H\341\273\215 v\303\240 T\303\252n ng\306\260\341\273\235i k\303\275 \341\273\237 b\341\272\243ng x\303\241c th\341\273\261c \304\221\303\263ng vai tr\303\262 kh\341\273\237i \304\221\341\273\231ng m\303\264-\304\221un sinh kh\303\263a PKCS#11 x\303\241c th\341\273\261c d\341\273\257 li\341\273\207u."
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                <span className=\"font-bold text-indigo-900 uppercase text-[11px] block\">1. Quy tr\303\254nh qu\341\272\243n l\303\275 t\341\273\225ng h\303\262a (K\303\275 s\341\273\221 &rarr; Th\341\272\251m \304\221\341\273\213nh &rarr; Gi\303\241m s\303\241t)</span>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  Chuy\303\252n vi\303\252n c\341\272\245p c\306\241 s\341\273\237 ho\303\240n thi\341\273\207n s\341\273\221 li\341\273\207u r\303\240 so\303\241t bi\341\273\203u m\341\272\253u, t\341\272\243i h\341\273\223 s\306\241 minh ch\341\273\251ng \304\221\303\255nh k\303\250m v\303\240 k\303\275 \304\221\303\263ng d\341\272\245u x\303\241c minh tr\306\260\341\273\233c khi g\341\273\255i n\341\273\231p. H\341\273\231i \304\221\341\273\223ng th\341\272\251m \304\221\341\273\213nh li\303\252n ng\303\240nh c\341\272\245p t\341\273\211nh ti\341\272\277p nh\341\272\255n ph\303\252 chu\341\272\251n, chuy\341\273\203n tr\341\272\241ng th\303\241i cho ban li\303\252n l\341\272\241c M\341\272\267t tr\341\272\255n T\341\273\225 Qu\341\273\221c \304\221\303\264n \304\221\341\273\221c gi\303\241m s\303\241t cu\341\273\221i c\303\271ng."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
