        }
        lines {
          text: "  { id: \"c9\", code: \"TC-09\", title: \"Nh\303\240 \341\273\237 v\303\240 m\341\272\255t \304\221\341\273\231 d\303\242n c\306\260 n\303\264ng th\303\264n\", description: \"Kh\303\264ng c\303\262n h\341\273\231 ngh\303\250o \341\273\237 trong nh\303\240 d\341\273\231t n\303\241t, t\341\272\241m b\341\273\243.\", indicator: \"Nh\303\240 \341\273\237 ki\303\252n c\341\273\221 \304\221\341\272\241t tr\303\252n 90%\", weight: \"15%\" },"
