    replacement_chunks {
      target_content: "import { LayoutDashboard, ClipboardList, ListCollapse, BarChart3, PlusCircle } from \'lucide-react\';\n\ninterface SidebarProps {\n  currentTab: \'overview\' | \'reports\' | \'criteria\' | \'statistics\';\n  onTabChange: (tab: \'overview\' | \'reports\' | \'criteria\' | \'statistics\') => void;\n  onNewReportClick: () => void;\n}\n\nexport default function Sidebar({ currentTab, onTabChange, onNewReportClick }: SidebarProps) {\n  const menuItems = [\n    { id: \'overview\' as const, label: \'T\341\273\225ng quan\', icon: LayoutDashboard },\n    { id: \'reports\' as const, label: \'\304\220\341\273\243t b\303\241o c\303\241o\', icon: ClipboardList },\n    { id: \'criteria\' as const, label: \'Qu\341\272\243n l\303\275 ti\303\252u ch\303\255\', icon: ListCollapse },\n    { id: \'statistics\' as const, label: \'B\303\241o c\303\241o th\341\273\221ng k\303\252\', icon: BarChart3 },\n  ];\n\n  return (\n    <aside className=\"w-64 h-screen fixed left-0 top-0 bg-white border-r border-surface-border flex flex-col pt-8 pb-6 z-50\">\n      {/* Brand & Crest Header */}\n      <div className=\"px-6 mb-8\">\n        <div className=\"flex items-center gap-3\">\n          <img\n            alt=\"Vietnam Government Crest\"\n            className=\"w-10 h-10 object-contain hover:scale-105 transition-transform duration-200\"\n            src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBYgmY9FpFS45i0Rg22DSLm_CMYUB-uUHTPBrMWpWvPe1xUwhroA8JfaWkh-W_XM7c3y72VhadirZt9gpim8wXi9FK9BRd8cwmDi58zJz6SnN-JpO5fRncrb7jHzFDyGDtGeXcHhMdLScsr5EpZRHsCZ0yFEusAQgqReklamTiAI28OjzIZYEuHnfBgb83wAfCowWnfV03DxJanO15wu0QBPpximkjweE5hu6I4dyltsxqAZoTgo_JDPw6Aq4trXgOEooDHPiCpbO0\"\n            referrerPolicy=\"no-referrer\"\n          />\n          <div>\n            <h1 className=\"text-lg font-bold text-primary leading-tight\">H\341\273\207 th\341\273\221ng B\303\241o c\303\241o</h1>\n            <p className=\"text-[10px] font-bold text-secondary/70 uppercase tracking-widest leading-none mt-0.5\">N\303\264ng th\303\264n m\341\273\233i</p>\n          </div>\n        </div>\n      </div>\n\n      {/* Navigation Menus */}\n      <nav className=\"flex-1 px-3 space-y-1\">\n        {menuItems.map((item) => {\n          const Icon = item.icon;\n          const isActive = currentTab === item.id;\n          return (\n            <button\n              key={item.id}\n              onClick={() => onTabChange(item.id)}\n              className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200 ${\n                isActive\n                  ? \'bg-data-logic-blue text-primary font-semibold shadow-sm border-l-4 border-primary\'\n                  : \'text-secondary hover:bg-surface-container-low hover:text-primary\'\n              }`}\n            >\n              <Icon className={`w-5 h-5 ${isActive ? \'text-primary\' : \'text-secondary/75\'}`} />\n              <span>{item.label}</span>\n            </button>\n          );\n        })}\n      </nav>\n\n      {/* Trigger New Report action */}\n      <div className=\"px-4 mt-auto\">\n        <button\n          onClick={onNewReportClick}\n          className=\"w-full py-3 bg-primary text-white rounded-lg flex items-center justify-center gap-2 text-xs font-bold hover:bg-primary-container transition-all shadow-md shadow-primary/15 hover:shadow-primary/25 active:scale-[0.98]\"\n        >\n          <PlusCircle className=\"w-4 h-4\" />\n          <span>T\341\272\241o b\303\241o c\303\241o m\341\273\233i</span>\n        </button>\n      </div>\n    </aside>\n  );\n}"
      replacement_content: "import { LayoutDashboard, ClipboardList, ListCollapse, BarChart3, PlusCircle, Award, Landmark } from \'lucide-react\';\n\ninterface SidebarProps {\n  currentTab: \'overview\' | \'reports\' | \'criteria\' | \'statistics\';\n  onTabChange: (tab: \'overview\' | \'reports\' | \'criteria\' | \'statistics\') => void;\n  onNewReportClick: () => void;\n}\n\nexport default function Sidebar({ currentTab, onTabChange, onNewReportClick }: SidebarProps) {\n  const menuItems = [\n    { id: \'overview\' as const, label: \'B\341\272\243ng \304\220i\341\273\201u Ch\341\273\211 \304\220\341\272\241o\', icon: LayoutDashboard },\n    { id: \'reports\' as const, label: \'\304\220\341\273\243t B\303\241o C\303\241o\', icon: ClipboardList },\n    { id: \'criteria\' as const, label: \'Qu\341\272\243n L\303\275 Ti\303\252u Ch\303\255\', icon: ListCollapse },\n    { id: \'statistics\' as const, label: \'B\303\241o C\303\241o Th\341\273\221ng K\303\252\', icon: BarChart3 },\n  ];\n\n  return (\n    <aside className=\"w-64 h-screen fixed left-0 top-0 bg-gradient-to-b from-[#081325] via-[#050e1c] to-[#02060c] text-white border-r border-white/5 flex flex-col pt-8 pb-6 z-50 shadow-[4px_0_24px_rgba(0,0,0,0.3)]\">\n      {/* Brand & Crest Header with premium design */}\n      <div className=\"px-6 mb-8\">\n        <div className=\"flex items-center gap-3 bg-white/5 p-3.5 rounded-2xl border border-white/10 relative overflow-hidden group\">\n          <div className=\"absolute top-[-20%] left-[-20%] w-16 h-16 bg-amber-400/10 rounded-full blur-xl pointer-events-none group-hover:bg-amber-400/20 transition-colors\" />\n          <img\n            alt=\"Vietnam Government Crest\"\n            className=\"w-10 h-10 object-contain hover:rotate-6 transition-transform duration-300 filter drop-shadow-[0_2px_8px_rgba(245,158,11,0.2)]\"\n            src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBYgmY9FpFS45i0Rg22DSLm_CMYUB-uUHTPBrMWpWvPe1xUwhroA8JfaWkh-W_XM7c3y72VhadirZt9gpim8wXi9FK9BRd8cwmDi58zJz6SnN-JpO5fRncrb7jHzFDyGDtGeXcHhMdLScsr5EpZRHsCZ0yFEusAQgqReklamTiAI28OjzIZYEuHnfBgb83wAfCowWnfV03DxJanO15wu0QBPpximkjweE5hu6I4dyltsxqAZoTgo_JDPw6Aq4trXgOEooDHPiCpbO0\"\n            referrerPolicy=\"no-referrer\"\n          />\n          <div className=\"z-10\">\n            <h1 className=\"text-sm font-bold text-slate-100 leading-tight tracking-wide group-hover:text-amber-400 transition-colors flex items-center gap-1.5\">\n              <span>H\341\273\207 Th\341\273\221ng NTM</span>\n            </h1>\n            <p className=\"text-[9px] font-extrabold text-amber-400/90 uppercase tracking-widest leading-none mt-1\">C\341\272\244P QU\341\273\220C GIA</p>\n          </div>\n        </div>\n      </div>\n\n      {/* Navigation Menus with custom styled items */}\n      <nav className=\"flex-1 px-3 space-y-1.5\">\n        {menuItems.map((item) => {\n          const Icon = item.icon;\n          const isActive = currentTab === item.id;\n          return (\n            <button\n              key={item.id}\n              onClick={() => onTabChange(item.id)}\n              className={`w-full flex items-center gap-3 px-4.5 py-3.5 rounded-xl text-xs font-semibold uppercase tracking-wider transition-all duration-200 cursor-pointer ${\n                isActive\n                  ? \'bg-gradient-to-r from-amber-500/20 to-amber-500/5 text-amber-400 border-l-4 border-amber-500 shadow-[inset_0_1px_10px_rgba(245,158,11,0.06)]\'\n                  : \'text-slate-400 hover:bg-white/5 hover:text-slate-100\'\n              }`}\n            >\n              <Icon className={`w-4 h-4 transition-transform group-hover:scale-110 ${isActive ? \'text-amber-400\' : \'text-slate-500\'}`} />\n              <span>{item.label}</span>\n            </button>\n          );\n        })}\n      </nav>\n\n      {/* System info / Legal badge placeholder */}\n      <div className=\"px-4.5 mb-4\">\n        <div className=\"bg-slate-900/40 border border-white/5 rounded-xl p-3 text-[9px] text-slate-400 leading-normal flex gap-2\">\n          <Landmark className=\"w-4 h-4 text-slate-500 shrink-0 mt-0.5\" />\n          <span>Phi\303\252n b\341\272\243n v26.04 Ch\303\255nh ph\341\273\247 \304\221i\341\273\207n t\341\273\255 - B\341\272\243n t\341\273\211nh t\303\255ch h\341\273\243p</span>\n        </div>\n      </div>\n\n      {/* Trigger New Report action */}\n      <div className=\"px-4 mt-auto\">\n        <button\n          onClick={onNewReportClick}\n          className=\"w-full py-3.5 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-slate-950 rounded-xl flex items-center justify-center gap-2 text-xs font-extrabold uppercase tracking-wide hover:shadow-[0_4px_15px_rgba(245,158,11,0.25)] transition-all cursor-pointer hover:scale-[1.01] active:scale-[0.99]\"\n        >\n          <PlusCircle className=\"w-4 h-4 shrink-0\" />\n          <span>T\341\272\241o B\303\241o C\303\241o M\341\273\233i</span>\n        </button>\n      </div>\n    </aside>\n  );\n}"
    }
