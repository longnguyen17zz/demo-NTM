        replacement_content: "  {\n    id: 10,\n    title: \"Ti\303\252u ch\303\255 10: Thu nh\341\272\255p & Ph\303\241t tri\341\273\203n kinh t\341\272\277\",\n    description: \"M\341\273\251c thu nh\341\272\255p b\303\254nh qu\303\242n \304\221\341\272\247u ng\306\260\341\273\235i c\341\273\247a x\303\243 \304\221\341\272\241t t\341\273\221i thi\341\273\203u t\341\273\253 53 tri\341\273\207u \304\221\341\273\223ng/ng\306\260\341\273\235i/n\304\203m tr\341\273\237 l\303\252n (\304\221i\341\273\201u ch\341\273\211nh t\304\203ng theo t\341\273\253ng n\304\203m v\303\240 t\341\273\253ng v\303\271ng c\341\273\245 th\341\273\203).\",\n    indicator: \"C\303\263 c\303\241c chu\341\273\227i m\303\264 h\303\254nh li\303\252n k\341\272\277t s\341\272\243n xu\341\272\245t n\303\264ng nghi\341\273\207p \341\273\251ng d\341\273\245ng c\303\264ng ngh\341\273\207 cao.\",\n    weight: \"15%\"\n  }\n];\n\nexport const INITIAL_DICTIONARY_CRITERIA = [\n  { id: \"c1\", code: \"TC-01\", title: \"Quy ho\341\272\241ch x\303\242y d\341\273\261ng x\303\243 n\303\264ng th\303\264n m\341\273\233i\", description: \"C\303\263 quy ho\341\272\241ch chung \304\221\306\260\341\273\243c ph\303\252 duy\341\273\207t v\303\240 qu\341\272\243n l\303\275 \304\221\303\272ng quy \304\221\341\273\213nh.\", indicator: \"T\341\273\267 l\341\273\207 quy ho\341\272\241ch \304\221\341\272\241t chu\341\272\251n 100%\", weight: \"10%\" },\n  { id: \"c2\", code: \"TC-02\", title: \"Giao th\303\264ng ki\303\252n c\341\273\221 h\303\263a n\303\264ng th\303\264n\", description: \"Nh\341\273\261a h\303\263a, b\303\252 t\303\264ng h\303\263a h\341\273\207 th\341\273\221ng tr\341\273\245c \304\221\306\260\341\273\235ng li\303\252n x\303\243, th\303\264n b\341\272\243n.\", indicator: \"\304\220\306\260\341\273\235ng li\303\252n th\303\264n \304\221\341\272\241t chu\341\272\251n t\341\273\221i thi\341\273\203u 70%\", weight: \"15%\" },\n  { id: \"c3\", code: \"TC-03\", title: \"Th\341\273\247y l\341\273\243i v\303\240 