  file_change {
    absolute_path_uri: "file:///src/components/ReportPeriodsTab.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport {\n  Calendar,\n  Layers,\n  PlusCircle,\n  FileEdit,\n  Trash2,\n  Eye,\n  Clock,\n  AlertTriangle,\n  FolderSync,\n  HelpCircle,\n  X,\n  FileSpreadsheet,\n  CheckCircle,\n  ShieldCheck,\n  Activity\n} from \'lucide-react\';\nimport { ReportPeriod, UserSession } from \'../types\';\nimport { createDefaultFormsForPeriod } from \'../mockData\';\n\ninterface ReportPeriodsTabProps {\n  periods: ReportPeriod[];\n  userSession: UserSession;\n  onSelectForm: (periodId: string, formId: string) => void;\n  onAddPeriod: (newPeriod: ReportPeriod) => void;\n  onEditPeriod: (updatedPeriod: ReportPeriod) => void;\n  onDeletePeriod: (id: string) => void;\n}\n\nexport default function ReportPeriodsTab({\n  periods,\n  userSession,\n  onSelectForm,\n  onAddPeriod,\n  onEditPeriod,\n  onDeletePeriod,\n}: ReportPeriodsTabProps) {\n  // Navigation inside the tab\n  const [selectedPeriodId, setSelectedPeriodId] = useState<string | null>(null);\n\n  // Modal / Form controls\n  const [showAddModal, setShowAddModal] = useState(false);\n  const [showEditModal, setShowEditModal] = useState(false);\n  const [activePeriod, setActivePeriod] = useState<ReportPeriod | null>(null);\n\n  // Form Fields\n  const [pName, setPName] = useState(\'\');\n  const [pYear, setPYear] = useState(\'2024\');\n  const [pTerm, setPTerm] = useState(\'6 th\303\241ng \304\221\341\272\247u n\304\203m\');\n  const [pDeadline, setPDeadline] = useState(\'2024-06-30\');\n\n  const selectedPeriod = periods.find((p) => p.id === selectedPeriodId);\n\n  const handleOpenAdd = () => {\n    setPName(\'\304\220\341\273\243t r\303\240 so\303\241t ti\341\272\277n \304\221\341\273\231 N\303\264ng th\303\264n m\341\273\233i H\341\273\215c k\341\273\263 I n\304\203m 2024\');\n    setPYear(\'2024\');\n    setPTerm(\'6 th\303\241ng \304\221\341\272\247u n\304\203m\');\n    setPDeadline(\'2024-06-30\');\n    setShowAddModal(true);\n  };\n\n  const handleCreatePeriod = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!pName.trim()) return;\n\n    const id = `${pYear}-${pTerm.toLowerCase().replace(/\\s+/g, \'\')}-${Date.now().toString().slice(-4)}`;\n    const newPeriod: ReportPeriod = {\n      id,\n      name: pName,\n      year: pYear,\n      term: pTerm,\n      deadline: pDeadline,\n      forms: createDefaultFormsForPeriod(id),\n    };\n\n    onAddPeriod(newPeriod);\n    setSelectedPeriodId(id); // auto select\n    setShowAddModal(false);\n  };\n\n  const handleOpenEdit = (period: ReportPeriod, e: React.MouseEvent) => {\n    e.stopPropagation();\n    setActivePeriod(period);\n    setPName(period.name);\n    setPYear(period.year);\n    setPTerm(period.term);\n    setPDeadline(period.deadline);\n    setShowEditModal(true);\n  };\n\n  const handleSaveEdit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!activePeriod || !pName.trim()) return;\n\n    const updated: ReportPeriod = {\n      ...activePeriod,\n      name: pName,\n      year: pYear,\n      term: pTerm,\n      deadline: pDeadline,\n    };\n\n    onEditPeriod(updated);\n    setShowEditModal(false);\n    setActivePeriod(null);\n  };\n\n  const handleDelete = (id: string, e: React.MouseEvent) => {\n    e.stopPropagation();\n    if (confirm(\'B\341\272\241n c\303\263 th\341\273\261c s\341\273\261 mu\341\273\221n x\303\263a \304\221\341\273\243t b\303\241o c\303\241o n\303\240y c\303\271ng to\303\240n b\341\273\231 c\303\241c m\341\272\253u bi\341\273\203u 04-13 \304\221\303\255nh k\303\250m?\')) {\n      onDeletePeriod(id);\n      if (selectedPeriodId === id) {\n        setSelectedPeriodId(null);\n      }\n    }\n  };\n\n  return (\n    <div className=\"space-y-6 text-slate-800 font-sans\">\n      {/* Tab Context Header */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-100 pb-3\">\n        <div>\n          <h2 className=\"text-lg font-bold text-slate-800 flex items-center gap-2\">\n            <Calendar className=\"w-5 h-5 text-primary\" />\n            <span>Qu\341\272\243n l\303\275 \304\220\341\273\243t b\303\241o c\303\241o x\303\242y d\341\273\261ng NTM</span>\n          </h2>\n          <p className=\"text-xs text-secondary mt-1\">\n            Kh\341\273\237i t\341\272\241o, s\341\272\257p x\341\272\277p v\303\240 ph\341\272\243n h\341\273\223i c\303\241c chu tr\303\254nh \304\221\303\241nh gi\303\241 c\306\241 s\341\273\237 theo th\303\241ng/qu\303\275/n\341\273\255a n\304\203m\n          </p>\n        </div>\n\n        {userSession.role === \'EDITOR\' && (\n          <button\n            onClick={handleOpenAdd}\n            className=\"px-4.5 py-2.5 bg-primary text-white text-xs font-bold rounded-lg hover:bg-primary-container transition-all flex items-center gap-1.5 shadow-md shadow-primary/10 cursor-pointer\"\n          >\n            <PlusCircle className=\"w-4.5 h-4.5\" />\n            <span>Kh\341\273\237i t\341\272\241o \304\221\341\273\243t b\303\241o c\303\241o m\341\273\233i</span>\n          </button>\n        )}\n      </div>\n\n      {!selectedPeriodId ? (\n        /* Period Selection Grid (Standard CRUD list) */\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {periods.map((period) => {\n            // Calculate stats\n            const totalForms = period.forms.length;\n            const draftCount = period.forms.filter((f) => f.status === \'DRAFT\').length;\n            const submittedCount = period.forms.filter((f) => f.status === \'SUBMITTED\').length;\n            const approvedCount = period.forms.filter((f) => f.status === \'APPROVED\').length;\n            const supervisedCount = period.forms.filter((f) => f.status === \'SUPERVISED\').length;\n\n            return (\n              <div\n                key={period.id}\n                onClick={() => setSelectedPeriodId(period.id)}\n                className=\"bg-white p-5 rounded-2xl border border-surface-border shadow-sm hover:border-primary/50 hover:shadow-lg transition-all duration-200 cursor-pointer flex flex-col justify-between relative group\"\n              >\n                <div>\n                  <div className=\"flex items-center justify-between mb-3 border-b border-slate-50 pb-2\">\n                    <span className=\"text-[10px] font-bold text-indigo-700 bg-indigo-50 px-2.5 py-1 rounded-full uppercase\">\n                      N\304\203m {period.year} \342\200\242 {period.term}\n                    </span>\n                    <div className=\"flex items-center gap-1\">\n                      {userSession.role === \'EDITOR\' && (\n                        <>\n                          <button\n                            onClick={(e) => handleOpenEdit(period, e)}\n                            className=\"p-1.5 text-slate-400 hover:text-primary rounded-lg hover:bg-slate-50 transition-colors\"\n                            title=\"S\341\273\255a \304\221\341\273\243t\"\n                          >\n                            <FileEdit className=\"w-3.5 h-3.5\" />\n                          </button>\n                          <button\n                            onClick={(e) => handleDelete(period.id, e)}\n                            className=\"p-1.5 text-slate-400 hover:text-red-600 rounded-lg hover:bg-slate-50 transition-colors\"\n                            title=\"X\303\263a \304\221\341\273\243t\"\n                          >\n                            <Trash2 className=\"w-3.5 h-3.5\" />\n                          </button>\n                        </>\n                      )}\n                    </div>\n                  </div>\n\n                  <h3 className=\"text-sm font-extrabold text-slate-800 leading-snug group-hover:text-primary transition-colors mb-2\">\n                    {period.name}\n                  </h3>\n\n                  <div className=\"flex items-center gap-1.5 text-[10px] text-secondary font-medium mb-4\">\n                    <Clock className=\"w-3.5 h-3.5 text-amber-500\" />\n                    <span>H\341\272\241n n\341\273\231p: <strong className=\"text-slate-700\">{period.deadline}</strong></span>\n                  </div>\n                </div>\n\n                {/* mini workflow visualization */}\n                <div className=\"bg-slate-50 p-3.5 rounded-xl border border-slate-100 space-y-2\">\n                  <div className=\"flex items-center justify-between text-[10px] text-slate-500 font-bold border-b border-slate-200/50 pb-1.5\">\n                    <span>M\341\272\253u bi\341\273\203u 04 - 13</span>\n                    <span>T\341\273\267 l\341\273\207 ti\341\272\277n tri\341\273\203n</span>\n                  </div>\n                  <div className=\"grid grid-cols-4 gap-1 text-center font-mono\">\n                    <div className=\"p-1 bg-white border rounded\">\n                      <span className=\"block text-[8px] text-secondary font-bold font-sans\">NH\303\201P</span>\n                      <strong className=\"text-xs text-slate-600\">{draftCount}</strong>\n                    </div>\n                    <div className=\"p-1 bg-sky-50 border border-sky-100 rounded\">\n                      <span className=\"block text-[8px] text-sky-600 font-bold font-sans\">G\341\273\254I</span>\n                      <strong className=\"text-xs text-sky-700\">{submittedCount}</strong>\n                    </div>\n                    <div className=\"p-1 bg-emerald-50 border border-emerald-100 rounded\">\n                      <span className=\"block text-[8px] text-emerald-600 font-bold font-sans font-viet\">Duy\341\273\207t</span>\n                      <strong className=\"text-xs text-emerald-700\">{approvedCount}</strong>\n                    </div>\n                    <div className=\"p-1 bg-indigo-50 border border-indigo-100 rounded\">\n                      <span className=\"block text-[8px] text-indigo-600 font-bold font-sans\">M-S\303\201T</span>\n                      <strong className=\"text-xs text-indigo-700\">{supervisedCount}</strong>\n                    </div>\n                  </div>\n\n                  {/* progress bar */}\n                  <div className=\"w-full bg-slate-200 h-1.5 rounded-full overflow-hidden mt-2\">\n                    <div\n                      className=\"bg-primary h-full rounded-full transition-all duration-500\"\n                      style={{\n                        width: `${((approvedCount + supervisedCount) / (totalForms || 1)) * 100}%`,\n                      }}\n                    />\n                  </div>\n                </div>\n\n                {/* Button actions */}\n                <div className=\"mt-4 flex justify-end\">\n                  <span className=\"text-[10px] font-extrabold text-primary flex items-center gap-1 group-hover:translate-x-1 transition-transform\">\n                    <span>Xem chi ti\341\272\277t \304\221\341\273\243t (Bi\341\273\203u 04-13)</span>\n                    <Eye className=\"w-3.5 h-3.5\" />\n                  </span>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      ) : (\n        /* Period detailed forms overview (Bi\341\273\203u 04-13 list) */\n        <div className=\"space-y-6\">\n          {/* Active Period header bar */}\n          <div className=\"bg-white p-5 rounded-2xl border border-surface-border shadow-sm flex flex-col sm:flex-row items-center justify-between gap-4\">\n            <div className=\"flex items-center gap-3\">\n              <div className=\"p-3 bg-indigo-50 rounded-xl text-primary font-bold\">\n                <FolderSync className=\"w-6 h-6\" />\n              </div>\n              <div>\n                <button\n                  onClick={() => setSelectedPeriodId(null)}\n                  className=\"text-xs font-bold text-slate-400 hover:text-primary mb-0.5 tracking-tight\"\n                >\n                  &larr; Quay v\341\273\201 danh s\303\241ch c\303\241c \304\221\341\273\243t\n                </button>\n                <h3 className=\"text-base font-extrabold text-slate-800\">{selectedPeriod?.name}</h3>\n                <p className=\"text-[10px] text-secondary font-medium uppercase mt-0.5 tracking-wider\">\n                  Bao g\341\273\223m \304\221\341\272\247y \304\221\341\273\247 10 ph\341\273\245 bi\341\273\203u chuy\303\252n ng\303\240nh (Bi\341\273\203u 04 \304\221\341\272\277n Bi\341\273\203u 13)\n                </p>\n              </div>\n            </div>\n\n            {/* Quick status counters */}\n            <div className=\"flex gap-2 text-[10px] font-mono shrink-0\">\n              <div className=\"px-2.5 py-1.5 bg-slate-100 rounded-lg border border-slate-200 flex items-center gap-1\">\n                <span className=\"w-2 h-2 rounded-full bg-slate-400\" />\n                <span>Nh\303\241p: {selectedPeriod?.forms.filter((f) => f.status === \'DRAFT\').length}</span>\n              </div>\n              <div className=\"px-2.5 py-1.5 bg-sky-50 text-sky-700 rounded-lg border border-sky-100 flex items-center gap-1\">\n                <span className=\"w-2 h-2 rounded-full bg-sky-500 animate-pulse\" />\n                <span>\304\220\303\243 n\341\273\231p: {selectedPeriod?.forms.filter((f) => f.status === \'SUBMITTED\').length}</span>\n              </div>\n              <div className=\"px-2.5 py-1.5 bg-emerald-50 text-emerald-700 rounded-lg border border-emerald-100 flex items-center gap-1\">\n                <span className=\"w-2 h-2 rounded-full bg-emerald-500\" />\n                <span>\304\220\341\272\241t chu\341\272\251n: {selectedPeriod?.forms.filter((f) => f.status === \'APPROVED\').length}</span>\n              </div>\n              <div className=\"px-2.5 py-1.5 bg-indigo-50 text-indigo-700 rounded-lg border border-indigo-100 flex items-center gap-1\">\n                <span className=\"w-2 h-2 rounded-full bg-indigo-600\" />\n                <span>\304\220\303\243 gi\303\241m s\303\241t: {selectedPeriod?.forms.filter((f) => f.status === \'SUPERVISED\').length}</span>\n              </div>\n            </div>\n          </div>\n\n          {/* Grid list of Forms 04-13 with detailed status */}\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            {selectedPeriod?.forms.map((form, index) => {\n              const statusColors = {\n                DRAFT: \'bg-slate-50 text-slate-600 border-slate-200\',\n                SUBMITTED: \'bg-amber-50 text-amber-700 border-amber-200\',\n                APPROVED: \'bg-emerald-50 text-emerald-700 border-emerald-200\',\n                SUPERVISED: \'bg-indigo-50 text-indigo-700 border-indigo-200\',\n              };\n\n              const statusLabels = {\n                DRAFT: \'B\341\272\243n th\341\272\243o nh\303\241p\',\n                SUBMITTED: \'Ch\341\273\235 th\341\272\251m \304\221\341\273\213nh\',\n                APPROVED: \'\304\220\303\243 ph\303\252 chu\341\272\251n\',\n                SUPERVISED: \'\304\220\303\243 ho\303\240n th\303\240nh gi\303\241m s\303\241t\',\n              };\n\n              return (\n                <div\n                  key={form.code}\n                  className=\"bg-white p-6 rounded-2xl border border-surface-border hover:border-slate-300 shadow-sm transition-all duration-200 flex flex-col justify-between\"\n                >\n                  <div>\n                    <div className=\"flex items-center justify-between mb-3 pb-2 border-b border-slate-50\">\n                      <span className=\"text-xs font-bold text-white bg-slate-800 px-3 py-1 rounded-md uppercase tracking-wide\">\n                        {form.code}\n                      </span>\n                      <span className={`text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 border rounded-full ${statusColors[form.status]}`}>\n                        {statusLabels[form.status]}\n                      </span>\n                    </div>\n\n                    <h4 className=\"text-sm font-extrabold text-slate-800 leading-snug mb-2 hover:text-primary transition-colors cursor-pointer\"\n                        onClick={() => onSelectForm(selectedPeriod.id, form.code)}>\n                      {form.title}\n                    </h4>\n\n                    <p className=\"text-xs text-secondary leading-relaxed line-clamp-2\">\n                      Bao g\341\273\223m h\341\273\207 th\341\273\221ng 10 ch\341\273\211 s\341\273\221 \304\221\303\241nh gi\303\241 k\341\273\271 thu\341\272\255t, theo d\303\265i c\306\241 c\341\272\245u v\303\240 \304\221\341\273\213nh l\306\260\341\273\243ng k\341\272\277 ho\341\272\241ch.\n                    </p>\n\n                    {/* Meta review logs if available */}\n                    <div className=\"mt-4 space-y-1 text-[10px] font-medium text-slate-400\">\n                      {form.editor && (\n                        <div className=\"flex justify-between\">\n                          <span>Ng\306\260\341\273\235i c\341\272\255p nh\341\272\255t:</span>\n                          <span className=\"text-slate-600 font-semibold\">{form.editor}</span>\n                        </div>\n                      )}\n                      {form.appraisal && (\n                        <div className=\"flex justify-between\">\n                          <span>Th\341\272\251m \304\221\341\273\213nh b\341\273\237i:</span>\n                          <span className=\"text-emerald-600 font-semibold\">{form.appraisal.appraiserName}</span>\n                        </div>\n                      )}\n                      {form.supervision && (\n                        <div className=\"flex justify-between\">\n                          <span>Gi\303\241m s\303\241t b\341\273\237i:</span>\n                          <span className=\"text-indigo-600 font-semibold\">{form.supervision.supervisorName}</span>\n                        </div>\n                      )}\n                    </div>\n                  </div>\n\n                  {/* Submit actions bottom button inside the form box */}\n                  <div className=\"mt-6 pt-4 border-t border-slate-100 flex items-center justify-between gap-4\">\n                    <span className=\"text-[10px] text-secondary font-mono\">\n                      {form.proofFiles.length} t\341\273\207p ch\341\273\251ng th\341\273\261c\n                    </span>\n                    <button\n                      onClick={() => onSelectForm(selectedPeriod.id, form.code)}\n                      className={`px-5 py-2 rounded-lg text-xs font-bold transition-all shrink-0 cursor-pointer ${\n                        form.status === \'DRAFT\'\n                          ? \'bg-slate-100 hover:bg-slate-200 text-slate-700\'\n                          : form.status === \'SUBMITTED\' && userSession.role === \'APPRAISER\'\n                          ? \'bg-emerald-600 hover:bg-emerald-700 text-white shadow-md shadow-emerald-600/10\'\n                          : form.status === \'APPROVED\' && userSession.role === \'SUPERVISOR\'\n                          ? \'bg-indigo-600 hover:bg-indigo-700 text-white shadow-md shadow-indigo-600/10\'\n                          : \'bg-slate-50 hover:bg-slate-100 text-slate-600\'\n                      }`}\n                    >\n                      {form.status === \'DRAFT\'\n                        ? \'C\341\272\255p nh\341\272\255t s\341\273\221 li\341\273\207u\'\n                        : form.status === \'SUBMITTED\' && userSession.role === \'APPRAISER\'\n                        ? \'Ti\341\272\277n h\303\240nh Th\341\272\251m \304\221\341\273\213nh &rarr;\'\n                        : form.status === \'APPROVED\' && userSession.role === \'SUPERVISOR\'\n                        ? \'Ti\341\272\277n h\303\240nh Gi\303\241m s\303\241t &rarr;\'\n                        : \'Xem chi ti\341\272\277t\'}\n                    </button>\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </div>\n      )}\n\n      {/* CRUD Reporting Period Create Modal */}\n      {showAddModal && (\n        <div className=\"fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center z-50 p-4\">\n          <div className=\"bg-white rounded-2xl max-w-md w-full p-6 shadow-2xl border border-slate-100 animate-slide-up\">\n            <div className=\"flex justify-between items-start mb-4\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"p-2 bg-indigo-50 text-indigo-600 rounded-lg\">\n                  <Calendar className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"text-sm font-extrabold text-slate-900 font-sans\">Kh\341\273\237i t\341\272\241o \304\221\341\273\243t b\303\241o c\303\241o m\341\273\233i</h4>\n                  <p className=\"text-[10px] text-secondary\">T\341\272\241o b\341\273\231 khung Bi\341\273\203u m\341\272\253u 04-13 cho ni\303\252n \304\221\341\273\231 b\303\241o c\303\241o</p>\n                </div>\n              </div>\n              <button onClick={() => setShowAddModal(false)} className=\"text-slate-400 hover:text-slate-700\">\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            <form onSubmit={handleCreatePeriod} className=\"space-y-4\">\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1 font-sans\">T\303\252n \304\221\341\273\243t b\303\241o c\303\241o</label>\n                <input\n                  type=\"text\"\n                  required\n                  value={pName}\n                  onChange={(e) => setPName(e.target.value)}\n                  placeholder=\"V\303\255 d\341\273\245: \304\220\341\273\243t b\303\241o c\303\241o NTM 6 th\303\241ng \304\221\341\272\247u n\304\203m 2024\"\n                  className=\"w-full text-xs p-2.5 duration-200 border border-slate-300 rounded-lg outline-none focus:ring-2 focus:ring-primary/25 bg-slate-50 font-semibold text-slate-800\"\n                />\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"text-xs font-bold text-slate-700 block mb-1 font-sans\">N\304\203m quy ho\341\272\241ch</label>\n                  <select\n                    value={pYear}\n                    onChange={(e) => setPYear(e.target.value)}\n                    className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold\"\n                  >\n                    <option value=\"2024\">N\304\203m 2024</option>\n                    <option value=\"2025\">N\304\203m 2025</option>\n                    <option value=\"2026\">N\304\203m 2026</option>\n                  </select>\n                </div>\n\n                <div>\n                  <label className=\"text-xs font-bold text-slate-700 block mb-1 font-sans\">K\341\273\263 b\303\241o c\303\241o n\341\273\231p</label>\n                  <select\n                    value={pTerm}\n                    onChange={(e) => setPTerm(e.target.value)}\n                    className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold\"\n                  >\n                    <option value=\"6 th\303\241ng \304\221\341\272\247u n\304\203m\">6 Th\303\241ng \304\221\341\272\247u n\304\203m</option>\n                    <option value=\"To\303\240n di\341\273\207n c\341\272\243 n\304\203m\">To\303\240n di\341\273\207n c\341\272\243 n\304\203m</option>\n                  </select>\n                </div>\n              </div>\n\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1 font-sans\">H\341\272\241n ch\303\263t g\341\273\255i b\303\241o c\303\241o</label>\n                <input\n                  type=\"date\"\n                  required\n                  value={pDeadline}\n                  onChange={(e) => setPDeadline(e.target.value)}\n                  className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold text-slate-800\"\n                />\n              </div>\n\n              <div className=\"bg-amber-50 p-3 rounded-xl border border-amber-200/50 flex gap-2\">\n                <AlertTriangle className=\"w-4.5 h-4.5 text-amber-600 shrink-0 mt-0.5\" />\n                <p className=\"text-[10px] text-amber-800 leading-normal\">\n                  Ch\303\272 \303\275: Kh\341\273\237i t\341\272\241o \304\221\341\273\243t b\303\241o c\303\241o s\341\272\275 t\341\273\261 \304\221\341\273\231ng nh\303\242n b\341\272\243n h\341\273\207 th\341\273\221ng 10 ph\341\273\245 bi\341\273\203u qu\341\273\221c gia (Bi\341\273\203u 04 \304\221\341\272\277n Bi\341\273\203u 13) ch\341\273\251a t\341\272\255p tin ch\341\273\211 s\341\273\221 \304\221\303\241nh gi\303\241 th\341\273\261c t\341\272\277 t\341\273\253 kho m\341\272\253u g\341\273\221c.\n                </p>\n              </div>\n\n              <div className=\"flex gap-3 pt-2\">\n                <button\n                  type=\"button\"\n                  onClick={() => setShowAddModal(false)}\n                  className=\"flex-1 py-2.5 border border-slate-300 text-slate-600 text-xs font-bold rounded-lg hover:bg-slate-50\"\n                >\n                  H\341\273\247y b\341\273\217\n                </button>\n                <button\n                  type=\"submit\"\n                  className=\"flex-1 py-2.5 bg-primary text-white text-xs font-bold rounded-lg hover:bg-primary-container shadow-md shadow-primary/10\"\n                >\n                  Kh\341\273\237i t\341\272\241o \304\221\341\273\243t\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n\n      {/* CRUD Reporting Period Edit Modal */}\n      {showEditModal && (\n        <div className=\"fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center z-50 p-4\">\n          <div className=\"bg-white rounded-2xl max-w-md w-full p-6 shadow-2xl border border-slate-100 animate-slide-up\">\n            <div className=\"flex justify-between items-start mb-4\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"p-2 bg-indigo-50 text-indigo-600 rounded-lg\">\n                  <FileEdit className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"text-sm font-extrabold text-slate-900 font-sans\">Hi\341\273\207u ch\341\273\211nh \304\221\341\273\243t b\303\241o c\303\241o</h4>\n                  <p className=\"text-[10px] text-secondary\">C\341\272\255p nh\341\272\255t tham s\341\273\221 c\303\240i \304\221\341\272\267t c\341\273\247a \304\221\341\273\243t b\303\241o c\303\241o</p>\n                </div>\n              </div>\n              <button onClick={() => setShowEditModal(false)} className=\"text-slate-400 hover:text-slate-700\">\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            <form onSubmit={handleSaveEdit} className=\"space-y-4\">\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1 font-sans font-medium\">T\303\252n \304\221\341\273\243t b\303\241o c\303\241o</label>\n                <input\n                  type=\"text\"\n                  required\n                  value={pName}\n                  onChange={(e) => setPName(e.target.value)}\n                  className=\"w-full text-xs p-2.5 duration-200 border border-slate-300 rounded-lg outline-none focus:ring-2 focus:ring-primary/25 bg-slate-50 font-semibold text-slate-800\"\n                />\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"text-xs font-bold text-slate-700 block mb-1 font-sans font-medium\">N\304\203m quy ho\341\272\241ch</label>\n                  <select\n                    value={pYear}\n                    onChange={(e) => setPYear(e.target.value)}\n                    className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold\"\n                  >\n                    <option value=\"2024\">N\304\203m 2024</option>\n                    <option value=\"2025\">N\304\203m 2025</option>\n                    <option value=\"2026\">N\304\203m 2026</option>\n                  </select>\n                </div>\n\n                <div>\n                  <label className=\"text-xs font-bold text-slate-700 block mb-1 font-sans font-medium\">K\341\273\263 b\303\241o c\303\241o n\341\273\231p</label>\n                  <select\n                    value={pTerm}\n                    onChange={(e) => setPTerm(e.target.value)}\n                    className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold\"\n                  >\n                    <option value=\"6 th\303\241ng \304\221\341\272\247u n\304\203m\">6 Th\303\241ng \304\221\341\272\247u n\304\203m</option>\n                    <option value=\"To\303\240n di\341\273\207n c\341\272\243 n\304\203m\">To\303\240n di\341\273\207n c\341\272\243 n\304\203m</option>\n                  </select>\n                </div>\n              </div>\n\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1 font-sans font-medium\">H\341\272\241n ch\303\263t g\341\273\255i b\303\241o c\303\241o</label>\n                <input\n                  type=\"date\"\n                  required\n                  value={pDeadline}\n                  onChange={(e) => setPDeadline(e.target.value)}\n                  className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold text-slate-800\"\n  