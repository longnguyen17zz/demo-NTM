    instruction: "Style the reporting period card selections and list of official forms to look highly polished and premium with elegant flow tags, soft gradients, and custom action layouts."
    replacement_infos {
      original_chunk {
        target_content: "      {!selectedPeriodId ? (\n        /* Period Selection Grid (Standard CRUD list) */\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {periods.map((period) => {\n            // Calculate stats\n            const totalForms = period.forms.length;\n            const draftCount = period.forms.filter((f) => f.status === \'DRAFT\').length;\n            const submittedCount = period.forms.filter((f) => f.status === \'SUBMITTED\').length;\n            const approvedCount = period.forms.filter((f) => f.status === \'APPROVED\').length;\n            const supervisedCount = period.forms.filter((f) => f.status === \'SUPERVISED\').length;\n\n            return (\n              <div\n                key={period.id}\n                onClick={() => setSelectedPeriodId(period.id)}\n                className=\"bg-white p-5 rounded-2xl border border-surface-border shadow-sm hover:border-primary/50 hover:shadow-lg transition-all duration-200 cursor-pointer flex flex-col justify-between relative group\"\n              >\n                <div>\n                  <div className=\"flex items-center justify-between mb-3 border-b border-slate-50 pb-2\">\n                    <span className=\"text-[10px] font-bold text-indigo-700 bg-indigo-50 px-2.5 py-1 rounded-full uppercase\">\n                      N\304\203m {period.year} \342\200\242 {period.term}\n                    </span>\n                    <div className=\"flex items-center gap-1\">\n                      {userSession.role === \'EDITOR\' && (\n                        <>\n                          <button\n                            onClick={(e) => handleOpenEdit(period, e)}\n                            className=\"p-1.5 text-slate-400 hover:text-primary rounded-lg hover:bg-slate-50 transition-colors\"\n                            title=\"S\341\273\255a \304\221\341\273\243t\"\n                          >\n                            <FileEdit className=\"w-3.5 h-3.5\" />\n                          </button>\n                          <button\n                            onClick={(e) => handleDelete(period.id, e)}\n                            className=\"p-1.5 text-slate-400 hover:text-red-600 rounded-lg hover:bg-slate-50 transition-colors\"\n                            title=\"X\303\263a \304\221\341\273\243t\"\n                          >\n                            <Trash2 className=\"w-3.5 h-3.5\" />\n                          </button>\n                        </>\n                      )}\n                    </div>\n                  </div>\n\n                  <h3 className=\"text-sm font-extrabold text-slate-800 leading-snug group-hover:text-primary transition-colors mb-2\">\n                    {period.name}\n                  </h3>\n\n                  <div className=\"flex items-center gap-1.5 text-[10px] text-secondary font-medium mb-4\">\n                    <Clock className=\"w-3.5 h-3.5 text-amber-500\" />\n                    <span>H\341\272\241n n\341\273\231p: <strong className=\"text-slate-700\">{period.deadline}</strong></span>\n                  </div>\n                </div>\n\n                {/* mini workflow visualization */}\n                <div className=\"bg-slate-50 p-3.5 rounded-xl border border-slate-100 space-y-2\">\n                  <div className=\"flex items-center justify-between text-[10px] text-slate-500 font-bold border-b border-slate-200/50 pb-1.5\">\n                    <span>M\341\272\253u bi\341\273\203u 04 - 13</span>\n                    <span>T\341\273\267 l\341\273\207 ti\341\272\277n tri\341\273\203n</span>\n                  </div>\n                  <div className=\"grid grid-cols-4 gap-1 text-center font-mono\">\n                    <div className=\"p-1 bg-white border rounded\">\n                      <span className=\"block text-[8px] text-secondary font-bold font-sans\">NH\303\201P</span>\n                      <strong className=\"text-xs text-slate-600\">{draftCount}</strong>\n                    </div>\n                    <div className=\"p-1 bg-sky-50 border border-sky-100 rounded\">\n                      <span className=\"block text-[8px] text-sky-600 font-bold font-sans\">G\341\273\254I</span>\n                      <strong className=\"text-xs text-sky-700\">{submittedCount}</strong>\n                    </div>\n                    <div className=\"p-1 bg-emerald-50 border border-emerald-100 rounded\">\n                      <span className=\"block text-[8px] text-emerald-600 font-bold font-sans font-viet\">Duy\341\273\207t</span>\n                      <strong className=\"text-xs text-emerald-700\">{approvedCount}</strong>\n                    </div>\n                    <div className=\"p-1 bg-indigo-50 border border-indigo-100 rounded\">\n                      <span className=\"block text-[8px] text-indigo-600 font-bold font-sans\">M-S\303\201T</span>\n                      <strong className=\"text-xs text-indigo-700\">{supervisedCount}</strong>\n                    </div>\n                  </div>\n\n                  {/* progress bar */}\n                  <div className=\"w-full bg-slate-200 h-1.5 rounded-full overflow-hidden mt-2\">\n                    <div\n                      className=\"bg-primary h-full rounded-full transition-all duration-500\"\n                      style={{\n                        width: `${((approvedCount + supervisedCount) / (totalForms || 1)) * 100}%`,\n                      }}\n                    />\n                  </div>\n                </div>\n\n                {/* Button actions */}\n                <div className=\"mt-4 flex justify-end\">\n                  <span className=\"text-[10px] font-extrabold text-primary flex items-center gap-1 group-hover:translate-x-1 transition-transform\">\n                    <span>Xem chi ti\341\272\277t \304\221\341\273\243t (Bi\341\273\203u 04-13)</span>\n                    <Eye className=\"w-3.5 h-3.5\" />\n                  </span>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      ) : (\n        /* Period detailed forms overview (Bi\341\273\203u 04-13 list) */\n        <div className=\"space-y-6\">\n          {/* Active Period header bar */}\n          <div className=\"bg-white p-5 rounded-2xl border border-surface-border shadow-sm flex flex-col sm:flex-row items-center justify-between gap-4\">\n            <div className=\"flex items-center gap-3\">\n              <div className=\"p-3 bg-indigo-50 rounded-xl text-primary font-bold\">\n                <FolderSync className=\"w-6 h-6\" />\n              </div>\n              <div>\n                <button\n                  onClick={() => setSelectedPeriodId(null)}\n                  className=\"text-xs font-bold text-slate-400 hover:text-primary mb-0.5 tracking-tight\"\n                >\n                  &larr; Quay v\341\273\201 danh s\303\241ch c\303\241c \304\221\341\273\243t\n                </button>\n                <h3 className=\"text-base font-extrabold text-slate-800\">{selectedPeriod?.name}</h3>\n                <p className=\"text-[10px] text-secondary font-medium uppercase mt-0.5 tracking-wider\">\n                  Bao g\341\273\223m \304\221\341\272\247y \304\221\341\273\247 10 ph\341\273\245 bi\341\273\203u chuy\303\252n ng\303\240nh (Bi\341\273\203u 04 \304\221\341\272\277n Bi\341\273\203u 13)\n                </p>\n              </div>\n            </div>\n\n            {/* Quick status counters */}\n            <div className=\"flex gap-2 text-[10px] font-mono shrink-0\">\n              <div className=\"px-2.5 py-1.5 bg-slate-100 rounded-lg border border-slate-200 flex items-center gap-1\">\n                <span className=\"w-2 h-2 rounded-full bg-slate-400\" />\n                <span>Nh\303\241p: {selectedPeriod?.forms.filter((f) => f.status === \'DRAFT\').length}</span>\n              </div>\n              <div className=\"px-2.5 py-1.5 bg-sky-50 text-sky-700 rounded-lg border border-sky-100 flex items-center gap-1\">\n                <span className=\"w-2 h-2 rounded-full bg-sky-500 animate-pulse\" />\n                <span>\304\220\303\243 n\341\273\231p: {selectedPeriod?.forms.filter((f) => f.status === \'SUBMITTED\').length}</span>\n              </div>\n              <div className=\"px-2.5 py-1.5 bg-emerald-50 text-emerald-700 rounded-lg border border-emerald-100 flex items-center gap-1\">\n                <span className=\"w-2 h-2 rounded-full bg-emerald-500\" />\n                <span>\304\220\341\272\241t chu\341\272\251n: {selectedPeriod?.forms.filter((f) => f.status === \'APPROVED\').length}</span>\n              </div>\n              <div className=\"px-2.5 py-1.5 bg-indigo-50 text-indigo-700 rounded-lg border border-indigo-100 flex items-center gap-1\">\n                <span className=\"w-2 h-2 rounded-full bg-indigo-600\" />\n                <span>\304\220\303\243 gi\303\241m s\303\241t: {selectedPeriod?.forms.filter((f) => f.status === \'SUPERVISED\').length}</span>\n              </div>\n            </div>\n          </div>\n\n          {/* Grid list of Forms 04-13 with detailed status */}\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            {selectedPeriod?.forms.map((form, index) => {\n              const statusColors = {\n                DRAFT: \'bg-slate-50 text-slate-600 border-slate-200\',\n                SUBMITTED: \'bg-amber-50 text-amber-700 border-amber-200\',\n                APPROVED: \'bg-emerald-50 text-emerald-700 border-emerald-200\',\n                SUPERVISED: \'bg-indigo-50 text-indigo-700 border-indigo-200\',\n              };\n\n              const statusLabels = {\n                DRAFT: \'B\341\272\243n th\341\272\243o nh\303\241p\',\n                SUBMITTED: \'Ch\341\273\235 th\341\272\251m \304\221\341\273\213nh\',\n                APPROVED: \'\304\220\303\243 ph\303\252 chu\341\272\251n\',\n                SUPERVISED: \'\304\220\303\243 ho\303\240n th\303\240nh gi\303\241m s\303\241t\',\n              };\n\n              return (\n                <div\n                  key={form.code}\n                  className=\"bg-white p-6 rounded-2xl border border-surface-border hover:border-slate-300 shadow-sm transition-all duration-200 flex flex-col justify-between\"\n                >\n                  <div>\n                    <div className=\"flex items-center justify-between mb-3 pb-2 border-b border-slate-50\">\n                      <span className=\"text-xs font-bold text-white bg-slate-800 px-3 py-1 rounded-md uppercase tracking-wide\">\n                        {form.code}\n                      </span>\n                      <span className={`text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 border rounded-full ${statusColors[form.status]}`}>\n                        {statusLabels[form.status]}\n                      </span>\n                    </div>\n\n                    <h4 className=\"text-sm font-extrabold text-slate-800 leading-snug mb-2 hover:text-primary transition-colors cursor-pointer\"\n                        onClick={() => onSelectForm(selectedPeriod.id, form.code)}>\n                      {form.title}\n                    </h4>\n\n                    <p className=\"text-xs text-secondary leading-relaxed line-clamp-2\">\n                      Bao g\341\273\223m h\341\273\207 th\341\273\221ng 10 ch\341\273\211 s\341\273\221 \304\221\303\241nh gi\303\241 k\341\273\271 thu\341\272\255t, theo d\303\265i c\306\241 c\341\272\245u v\303\240 \304\221\341\273\213nh l\306\260\341\273\243ng k\341\272\277 ho\341\272\241ch.\n                    </p>\n\n                    {/* Meta review logs if available */}\n                    <div className=\"mt-4 space-y-1 text-[10px] font-medium text-slate-400\">\n                      {form.editor && (\n                        <div className=\"flex justify-between\">\n                          <span>Ng\306\260\341\273\235i c\341\272\255p nh\341\272\255t:</span>\n                          <span className=\"text-slate-600 font-semibold\">{form.editor}</span>\n                        </div>\n                      )}\n                      {form.appraisal && (\n                        <div className=\"flex justify-between\">\n                          <span>Th\341\272\251m \304\221\341\273\213nh b\341\273\237i:</span>\n                          <span className=\"text-emerald-600 font-semibold\">{form.appraisal.appraiserName}</span>\n                        </div>\n                      )}\n                      {form.supervision && (\n                        <div className=\"flex justify-between\">\n                          <span>Gi\303\241m s\303\241t b\341\273\237i:</span>\n                          <span className=\"text-indigo-600 font-semibold\">{form.supervision.supervisorName}</span>\n                        </div>\n                      )}\n                    </div>\n                  </div>\n\n                  {/* Submit actions bottom button inside the form box */}\n                  <div className=\"mt-6 pt-4 border-t border-slate-100 flex items-center justify-between gap-4\">\n                    <span className=\"text-[10px] text-secondary font-mono\">\n                      {form.proofFiles.length} t\341\273\207p ch\341\273\251ng th\341\273\261c\n                    </span>\n                    <button\n                      onClick={() => onSelectForm(selectedPeriod.id, form.code)}\n                      className={`px-5 py-2 rounded-lg text-xs font-bold transition-all shrink-0 cursor-pointer ${\n                        form.status === \'DRAFT\'\n                          ? \'bg-slate-100 hover:bg-slate-200 text-slate-700\'\n                          : form.status === \'SUBMITTED\' && userSession.role === \'APPRAISER\'\n                          ? \'bg-emerald-600 hover:bg-emerald-700 text-white shadow-md shadow-emerald-600/10\'\n                          : form.status === \'APPROVED\' && userSession.role === \'SUPERVISOR\'\n                          ? \'bg-indigo-600 hover:bg-indigo-700 text-white shadow-md shadow-indigo-600/10\'\n                          : \'bg-slate-50 hover:bg-slate-100 text-slate-600\'\n                      }`}\n                    >\n                      {form.status === \'DRAFT\'\n                        ? \'C\341\272\255p nh\341\272\255t s\341\273\221 li\341\273\207u\'\n                        : form.status === \'SUBMITTED\' && userSession.role === \'APPRAISER\'\n                        ? \'Ti\341\272\277n h\303\240nh Th\341\272\251m \304\221\341\273\213nh &rarr;\'\n                        : form.status === \'APPROVED\' && userSession.role === \'SUPERVISOR\'\n                        ? \'Ti\341\272\277n h\303\240nh Gi\303\241m s\303\241t &rarr;\'\n                        : \'Xem chi ti\341\272\277t\'}\n                    </button>\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </div>\n      )}"
        replacement_content: "      {!selectedPeriodId ? (\n        /* Period Selection Grid (Standard CRUD list) */\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {periods.map((period) => {\n            // Calculate stats\n            const totalForms = period.forms.length;\n            const draftCount = period.forms.filter((f) => f.status === \'DRAFT\').length;\n            const submittedCount = period.forms.filter((f) => f.status === \'SUBMITTED\').length;\n            const approvedCount = period.forms.filter((f) => f.status === \'APPROVED\').length;\n            const supervisedCount = period.forms.filter((f) => f.status === \'SUPERVISED\').length;\n            const completionPercent = Math.round(((approvedCount + supervisedCount) / (totalForms || 1)) * 100);\n\n            return (\n              <div\n                key={period.id}\n                onClick={() => setSelectedPeriodId(period.id)}\n                className=\"bg-white p-6 rounded-3xl border border-slate-100 shadow-[0_4px_20px_rgba(0,0,0,0.02)] hover:border-amber-500 hover:shadow-[0_10px_30px_rgba(0,0,0,0.08)] transition-all duration-300 cursor-pointer flex flex-col justify-between relative group\"\n              >\n                <div>\n                  <div className=\"flex items-center justify-between mb-4 border-b border-slate-50 pb-3\">\n                    <span className=\"text-[10px] font-black text-amber-600 bg-amber-50 px-3 py-1.5 rounded-full uppercase tracking-wider border border-amber-500/10\">\n                      N\304\203m {period.year} \342\200\242 {period.term}\n                    </span>\n                    <div className=\"flex items-center gap-1\">\n                      {userSession.role === \'EDITOR\' && (\n                        <>\n                          <button\n                            onClick={(e) => handleOpenEdit(period, e)}\n                            className=\"p-2 text-slate-400 hover:text-amber-500 hover:bg-slate-50 rounded-xl transition-all\"\n                            title=\"S\341\273\255a \304\221\341\273\243t\"\n                          >\n                            <FileEdit className=\"w-3.5 h-3.5\" />\n                          </button>\n                          <button\n                            onClick={(e) => handleDelete(period.id, e)}\n                            className=\"p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all\"\n                            title=\"X\303\263a \304\221\341\273\243t\"\n                          >\n                            <Trash2 className=\"w-3.5 h-3.5\" />\n                          </button>\n                        </>\n                      )}\n                    </div>\n                  </div>\n\n                  <h3 className=\"text-sm font-black text-slate-800 leading-snug group-hover:text-amber-600 transition-colors mb-2\">\n                    {period.name}\n                  </h3>\n\n                  <div className=\"flex items-center gap-1.5 text-[10px] text-slate-400 font-extrabold uppercase tracking-wide mb-5\">\n                    <Clock className=\"w-3.5 h-3.5 text-amber-500\" />\n                    <span>H\341\272\241n n\341\273\231p: <strong className=\"text-slate-700 font-black\">{period.deadline}</strong></span>\n                  </div>\n                </div>\n\n                {/* mini workflow visualization */}\n                <div className=\"bg-slate-50/80 p-4 rounded-2xl border border-slate-100 space-y-3.5\">\n                  <div className=\"flex items-center justify-between text-[10px] text-slate-500 font-bold border-b border-slate-200/50 pb-2\">\n                    <span className=\"uppercase tracking-wider\">M\341\272\253u bi\341\273\203u 04 - 13</span>\n                    <span className=\"text-amber-600 font-black\">{completionPercent}% Ho\303\240n th\303\240nh</span>\n                  </div>\n                  <div className=\"grid grid-cols-4 gap-1.5 text-center font-mono\">\n                    <div className=\"p-1.5 bg-white border border-slate-100 rounded-xl shadow-[0_2px_4px_rgba(0,0,0,0.01)]\">\n                      <span className=\"block text-[8px] text-slate-400 font-bold font-sans\">NH\303\201P</span>\n                      <strong className=\"text-xs text-slate-700 font-black\">{draftCount}</strong>\n                    </div>\n                    <div className=\"p-1.5 bg-sky-50 border border-sky-100 rounded-xl\">\n                      <span className=\"block text-[8px] text-sky-500 font-bold font-sans\">G\341\273\254I</span>\n                      <strong className=\"text-xs text-sky-700 font-black\">{submittedCount}</strong>\n                    </div>\n                    <div className=\"p-1.5 bg-emerald-50 border border-emerald-100 rounded-xl\">\n                      <span className=\"block text-[8px] text-emerald-500 font-bold font-sans\">DUY\341\273\206T</span>\n                      <strong className=\"text-xs text-emerald-700 font-black\">{approvedCount}</strong>\n                    </div>\n                    <div className=\"p-1.5 bg-indigo-50 border border-indigo-100 rounded-xl\">\n                      <span className=\"block text-[8px] text-indigo-500 font-bold font-sans\">G-S\303\201T</span>\n                      <strong className=\"text-xs text-indigo-700 font-black\">{supervisedCount}</strong>\n                    </div>\n                  </div>\n\n                  {/* progress bar */}\n                  <div className=\"w-full bg-slate-200 h-2 rounded-full overflow-hidden mt-1 relative\">\n                    <div\n                      className=\"bg-gradient-to-r from-amber-500 to-amber-600 h-full rounded-full transition-all duration-500\"\n                      style={{\n                        width: `${completionPercent}%`,\n                      }}\n                    />\n                  </div>\n                </div>\n\n                {/* Button actions */}\n                <div className=\"mt-5 flex justify-end\">\n                  <span className=\"text-[10px] font-black uppercase text-amber-600 flex items-center gap-1 group-hover:translate-x-1.5 transition-transform tracking-wider\">\n                    <span>Xem bi\341\273\203u 04-13 c\341\273\247a \304\221\341\273\243t</span>\n                    <Eye className=\"w-4 h-4\" />\n                  </span>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      ) : (\n        /* Period detailed forms overview (Bi\341\273\203u 04-13 list) */\n        <div className=\"space-y-8\">\n          {/* Active Period header bar */}\n          <div className=\"bg-white p-6 rounded-3xl border border-slate-100 shadow-[0_4px_20px_rgba(0,0,0,0.02)] flex flex-col lg:flex-row items-center justify-between gap-6\">\n            <div className=\"flex items-center gap-4.5\">\n              <div className=\"p-3.5 bg-amber-500/10 text-amber-600 rounded-2xl font-bold border border-amber-500/10\">\n                <FolderSync className=\"w-6.5 h-6.5\" />\n              </div>\n              <div>\n                <button\n                  onClick={() => setSelectedPeriodId(null)}\n                  className=\"text-xs font-black text-slate-400 hover:text-amber-500 mb-1 transition-colors flex items-center gap-1.5 cursor-pointer uppercase tracking-wider\"\n                >\n                  &larr; T\341\272\245t c\341\272\243 c\303\241c \304\221\341\273\243t r\303\240 so\303\241t\n                </button>\n                <h3 className=\"text-base font-black text-slate-800 tracking-tight\">{selectedPeriod?.name}</h3>\n                <p className=\"text-[10px] text-slate-400 font-bold uppercase mt-1 tracking-widest flex items-center gap-1.5\">\n                  <Activity className=\"w-3.5 h-3.5 text-amber-500\" />\n                  <span>T\341\273\225ng h\341\273\243p s\341\273\225 tay r\303\240 so\303\241t ch\341\273\211 ti\303\252u B\341\273\231 ti\303\252u ch\303\255 Qu\341\273\221c gia</span>\n                </p>\n              </div>\n            </div>\n\n            {/* Quick status counters */}\n            <div className=\"flex flex-wrap gap-2 text-[10px] font-bold shrink-0\">\n              <div className=\"px-3 py-2 bg-slate-50 text-slate-500 rounded-xl border border-slate-100 flex items-center gap-1.5 shadow-[0_2px_4px_rgba(0,0,0,0.01)]\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-slate-400\" />\n                <span>Nh\303\241p: {selectedPeriod?.forms.filter((f) => f.status === \'DRAFT\').length}</span>\n              </div>\n              <div className=\"px-3 py-2 bg-amber-50/50 text-amber-700 rounded-xl border border-amber-100/50 flex items-center gap-1.5\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse\" />\n                <span>Th\341\272\251m duy\341\273\207t: {selectedPeriod?.forms.filter((f) => f.status === \'SUBMITTED\').length}</span>\n              </div>\n              <div className=\"px-3 py-2 bg-emerald-50 text-emerald-700 rounded-xl border border-emerald-100 flex items-center gap-1.5\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" />\n                <span>Ph\303\252 chu\341\272\251n: {selectedPeriod?.forms.filter((f) => f.status === \'APPROVED\').length}</span>\n              </div>\n              <div className=\"px-3 py-2 bg-indigo-50 text-indigo-700 rounded-xl border border-indigo-100 flex items-center gap-1.5\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-indigo-600 animate-pulse\" />\n                <span>Gi\303\241m s\303\241t: {selectedPeriod?.forms.filter((f) => f.status === \'SUPERVISED\').length}</span>\n              </div>\n            </div>\n          </div>\n\n          {/* Grid list of Forms 04-13 with detailed status */}\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            {selectedPeriod?.forms.map((form, index) => {\n              const statusColors = {\n                DRAFT: \'bg-slate-50 text-slate-500 border-slate-100\',\n                SUBMITTED: \'bg-amber-50/80 text-amber-700 border-amber-200/60 animate-pulse-slow\',\n                APPROVED: \'bg-emerald-50 text-emerald-700 border-emerald-200/50\',\n                SUPERVISED: \'bg-indigo-50 text-indigo-700 border-indigo-200/50\',\n              };\n\n              const statusLabels = {\n                DRAFT: \'B\341\272\243n th\341\272\243o nh\303\241p \342\200\242 X\303\243 l\341\272\255p\',\n                SUBMITTED: \'Ch\341\273\235 H\341\273\231i \304\221\341\273\223ng Th\341\272\251m duy\341\273\207t\',\n                APPROVED: \'H\341\273\231i \304\221\341\273\223ng ph\303\252 duy\341\273\207t\',\n                SUPERVISED: \'MTTQ \304\221\303\243 ho\303\240n th\303\240nh gi\303\241m s\303\241t\',\n              };\n\n              return (\n                <div\n                  key={form.code}\n                  className=\"bg-white p-6 rounded-3xl border border-slate-100 hover:border-slate-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.03)] shadow-[0_4px_20px_rgba(0,0,0,0.015)] transition-all duration-300 flex flex-col justify-between group\"\n                >\n                  <div>\n                    <div className=\"flex items-center justify-between mb-4 pb-3 border-b border-slate-50\">\n                      <span className=\"text-xs font-black text-slate-900 bg-slate-100 px-3 py-1.5 rounded-lg border border-slate-200/60 tracking-wider\">\n                        {form.code}\n                      </span>\n                      <span className={`text-[9px] font-bold uppercase tracking-wider px-3 py-1.5 border rounded-full ${statusColors[form.status]}`}>\n                        {statusLabels[form.status]}\n                      </span>\n                    </div>\n\n                    <h4 className=\"text-sm font-black text-slate-800 leading-snug mb-2 group-hover:text-amber-600 transition-colors cursor-pointer\"\n                        onClick={() => onSelectForm(selectedPeriod.id, form.code)}>\n                      {form.title}\n                    </h4>\n\n                    <p className=\"text-xs text-slate-400 leading-relaxed line-clamp-2 font-medium\">\n                      Bao g\341\273\223m b\341\273\231 10 ch\341\273\211 s\341\273\221 \304\221\303\241nh gi\303\241 th\341\273\261c k\341\273\271, ph\303\242n b\341\273\225 nh\303\263m \304\221\341\272\267c th\303\271 v\303\271ng n\303\272i \304\221\341\273\223ng b\341\272\261ng h\341\272\261ng n\304\203m.\n                    </p>\n\n                    {/* Meta review logs if available with gorgeous government style lines */}\n                    <div className=\"mt-5 space-y-1.5 text-[10px] font-bold uppercase tracking-wide text-slate-400 bg-slate-50/50 p-3.5 rounded-2xl border border-slate-100/50\">\n                      {form.editor && (\n                        <div className=\"flex justify-between items-center\">\n                          <span>Chuy\303\252n vi\303\252n l\341\272\255p:</span>\n                          <span className=\"text-slate-600 font-extrabold\">{form.editor}</span>\n                        </div>\n                      )}\n                      {form.appraisal && (\n                        <div className=\"flex justify-between items-center border-t border-slate-100/60 pt-1.5 mt-1.5\">\n                          <span>Ch\303\241nh V\304\203n ph\303\262ng th\341\272\251m:</span>\n                          <span className=\"text-emerald-600 font-extrabold\">{form.appraisal.appraiserName}</span>\n                        </div>\n                      )}\n                      {form.supervision && (\n                        <div className=\"flex justify-between items-center border-t border-slate-100/60 pt-1.5 mt-1.5\">\n                          <span>Gi\303\241m s\303\241t t\341\273\221i cao:</span>\n                          <span className=\"text-indigo-600 font-extrabold\">{form.supervision.supervisorName}</span>\n                        </div>\n                      )}\n                    </div>\n                  </div>\n\n                  {/* Submit actions bottom button inside the form box */}\n                  <div className=\"mt-6 pt-4 border-t border-slate-100 flex items-center justify-between gap-4\">\n                    <span className=\"text-[10px] text-slate-400 font-black uppercase tracking-wider bg-slate-50 px-2.5 py-1 rounded-md border border-slate-100/50\">\n                      {form.proofFiles.length} t\341\273\207p ch\341\273\251ng th\341\273\261c CA\n                    </span>\n                    <button\n                      onClick={() => onSelectForm(selectedPeriod.id, form.code)}\n                      className={`px-5 py-3 rounded-xl text-xs font-black uppercase tracking-wider transition-all duration-200 shrink-0 cursor-pointer shadow-sm ${\n                        form.status === \'DRAFT\'\n                          ? \'bg-slate-100 hover:bg-slate-200 text-slate-700\'\n                          : form.status === \'SUBMITTED\' && userSession.role === \'APPRAISER\'\n                          ? \'bg-emerald-600 hover:bg-emerald-500 text-white shadow-emerald-600/15 hover:shadow-[0_4px_15px_rgba(16,185,129,0.25)]\'\n                          : form.status === \'APPROVED\' && userSession.role === \'SUPERVISOR\'\n                          ? \'bg-indigo-600 hover:bg-indigo-500 text-white shadow-indigo-600/15 hover:shadow-[0_4px_15px_rgba(79,70,229,0.25)]\'\n                          : \'bg-slate-50 hover:bg-slate-100/80 text-slate-600\'\n                      }`}\n                    >\n                      {form.status === \'DRAFT\'\n                        ? \'C\341\272\255p nh\341\272\255t s\341\273\221 li\341\273\207u\'\n                        : form.status === \'SUBMITTED\' && userSession.role === \'APPRAISER\'\n                        ? \'Th\341\273\261c hi\341\273\207n Th\341\272\251m \304\220\341\273\213nh\'\n                        : form.status === \'APPROVED\' && userSession.role === \'SUPERVISOR\'\n                        ? \'Th\341\273\261c hi\341\273\207n Gi\303\241m S\303\241t\'\n                        : \'Xem d\341\273\257 li\341\273\207u m\341\272\253u\'}\n                    </button>\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </div>\n      )}"
      }
      num_matches: 1
    }
  }
