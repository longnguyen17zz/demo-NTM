        lines {
          text: "  { id: \"c6\", code: \"TC-06\", title: \"C\306\241 s\341\273\237 v\341\272\255t ch\341\272\245t v\304\203n h\303\263a c\341\273\231ng \304\221\341\273\223ng\", description: \"Nh\303\240 v\304\203n h\303\263a, khu th\341\273\203 thao x\303\243 \304\221\341\272\241t ti\303\252u ch\303\255 qu\341\273\221c gia.\", indicator: \"S\341\273\221 nh\303\240 v\304\203n h\303\263a \304\221\341\272\241t chu\341\272\251n tr\303\252n 70%\", weight: \"5%\" },"
