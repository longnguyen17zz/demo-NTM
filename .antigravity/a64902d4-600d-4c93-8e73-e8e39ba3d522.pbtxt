    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport {\n  Search,\n  BookOpen,\n  PlusCircle,\n  FileEdit,\n  Trash2,\n  Weight,\n  Award,\n  Info,\n  X,\n  FileText,\n  BookmarkCheck\n} from \'lucide-react\';\nimport { Criterion, UserSession } from \'../types\';\n\ninterface CriteriaTabProps {\n  criteria: Criterion[];\n  userSession: UserSession;\n  onAddCriterion: (newC: Criterion) => void;\n  onEditCriterion: (updatedC: Criterion) => void;\n  onDeleteCriterion: (id: string) => void;\n}\n\nexport default function CriteriaTab({\n  criteria,\n  userSession,\n  onAddCriterion,\n  onEditCriterion,\n  onDeleteCriterion,\n}: CriteriaTabProps) {\n  const [searchTerm, setSearchTerm] = useState(\'\');\n\n  // CRUD Form Overlay states\n  const [showAddModal, setShowAddModal] = useState(false);\n  const [showEditModal, setShowEditModal] = useState(false);\n  const [activeCriterion, setActiveCriterion] = useState<Criterion | null>(null);\n\n  // Form states\n  const [cCode, setCCode] = useState(\'\');\n  const [cTitle, setCTitle] = useState(\'\');\n  const [cDesc, setCDesc] = useState(\'\');\n  const [cIndicator, setCIndicator] = useState(\'\');\n  const [cWeight, setCWeight] = useState(\'\');\n\n  const filteredCriteria = criteria.filter(\n    (item) =>\n      item.title.toLowerCase().includes(searchTerm.toLowerCase()) ||\n      item.code.toLowerCase().includes(searchTerm.toLowerCase()) ||\n      item.description.toLowerCase().includes(searchTerm.toLowerCase())\n  );\n\n  const handleOpenAdd = () => {\n    const nextNum = criteria.length + 1;\n    setCCode(`TC-${nextNum < 10 ? \'0\' + nextNum : nextNum}`);\n    setCTitle(\'\');\n    setCDesc(\'\');\n    setCIndicator(\'\');\n    setCWeight(\'10%\');\n    setShowAddModal(true);\n  };\n\n  const handleCreate = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!cTitle.trim() || !cCode.trim()) return;\n\n    const newCriterion: Criterion = {\n      id: `c-${Date.now()}`,\n      code: cCode,\n      title: cTitle,\n      description: cDesc,\n      indicator: cIndicator,\n      weight: cWeight,\n    };\n\n    onAddCriterion(newCriterion);\n    setShowAddModal(false);\n  };\n\n  const handleOpenEdit = (c: Criterion) => {\n    setActiveCriterion(c);\n    setCCode(c.code);\n    setCTitle(c.title);\n    setCDesc(c.description);\n    setCIndicator(c.indicator);\n    setCWeight(c.weight);\n    setShowEditModal(true);\n  };\n\n  const handleSaveEdit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!activeCriterion || !cTitle.trim()) return;\n\n    const updated: Criterion = {\n      ...activeCriterion,\n      code: cCode,\n      title: cTitle,\n      description: cDesc,\n      indicator: cIndicator,\n      weight: cWeight,\n    };\n\n    onEditCriterion(updated);\n    setShowEditModal(false);\n    setActiveCriterion(null);\n  };\n\n  const handleDelete = (id: string) => {\n    if (confirm(\'B\341\272\241n c\303\263 ch\341\272\257c ch\341\272\257n mu\341\273\221n x\303\263a ti\303\252u ch\303\255 n\303\240y kh\341\273\217i s\341\273\225 tay h\341\273\207 th\341\273\221ng?\')) {\n      onDeleteCriterion(id);\n    }\n  };\n\n  return (\n    <div className=\"space-y-6 animate-fade-in text-slate-800 font-sans\">\n      {/* Subheader and Controls */}\n      <div className=\"bg-white p-6 rounded-2xl border border-surface-border shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4\">\n        <div>\n          <h3 className=\"text-sm font-bold text-slate-800 uppercase tracking-tight flex items-center gap-1.5\">\n            <BookmarkCheck className=\"w-5 h-5 text-primary\" />\n            <span>S\341\273\225 tay H\306\260\341\273\233ng d\341\272\253n \304\221\303\241nh gi\303\241 b\341\273\231 ti\303\252u th\341\272\277 Qu\341\273\221c gia</span>\n          </h3>\n          <p className=\"text-xs text-secondary mt-1\">\n            Tra c\341\273\251u v\303\240 c\341\272\245u h\303\254nh danh m\341\273\245c b\341\273\231 ti\303\252u ch\303\255 N\303\264ng th\303\264n m\341\273\233i giai \304\221o\341\272\241n 2021 - 2025\n          </p>\n        </div>\n\n        <div className=\"flex items-center gap-3 w-full md:w-auto\">\n          <div className=\"relative flex-1 md:w-64\">\n            <input\n              type=\"text\"\n              value={searchTerm}\n              onChange={(e) => setSearchTerm(e.target.value)}\n              placeholder=\"T\303\254m nhanh ti\303\252u ch\303\255...\"\n              className=\"w-full pl-9 pr-4 py-2.5 bg-slate-50 border border-slate-200 focus:border-primary rounded-xl text-xs outline-none transition-all focus:ring-2 focus:ring-primary/10\"\n            />\n            <Search className=\"w-4 h-4 text-slate-400 absolute left-3.5 top-1/2 -translate-y-1/2\" />\n          </div>\n\n          {userSession.role === \'EDITOR\' && (\n            <button\n              onClick={handleOpenAdd}\n              className=\"px-4 py-2.5 bg-primary text-white hover:bg-primary-container text-xs font-bold rounded-xl flex items-center gap-1.5 shrink-0 transition-all cursor-pointer\"\n            >\n              <PlusCircle className=\"w-4 h-4\" />\n              <span>Th\303\252m ti\303\252u ch\303\255</span>\n            </button>\n          )}\n        </div>\n      </div>\n\n      {/* Grid of Criteria cards */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n        {filteredCriteria.length === 0 ? (\n          <div className=\"md:col-span-2 text-center p-12 bg-white rounded-2xl border border-dashed border-slate-300\">\n            <BookOpen className=\"w-12 h-12 text-slate-300 mx-auto mb-3\" />\n            <p className=\"text-sm text-secondary font-medium\">Kh\303\264ng t\303\254m th\341\272\245y ti\303\252u ch\303\255 n\303\240o ph\303\271 h\341\273\243p</p>\n          </div>\n        ) : (\n          filteredCriteria.map((item) => (\n            <div\n              key={item.id}\n              className=\"bg-white p-6 rounded-2xl border border-surface-border shadow-sm flex flex-col justify-between hover:border-primary/40 hover:shadow-md transition-all duration-200 relative group\"\n            >\n              <div>\n                <div className=\"flex items-center justify-between mb-3 border-b border-slate-50 pb-2\">\n                  <span className=\"text-[10px] font-bold text-primary bg-indigo-50 px-3 py-1 rounded-full uppercase tracking-tight\">\n                    {item.code}\n                  </span>\n                  <div className=\"flex items-center gap-2\">\n                    <div className=\"flex items-center gap-1 text-[10px] bg-slate-100 text-slate-600 px-2 py-0.5 rounded font-mono\">\n                      <Weight className=\"w-3.5 h-3.5 text-secondary\" />\n                      <span>Tr\341\273\215ng s\341\273\221: {item.weight}</span>\n                    </div>\n\n                    {userSession.role === \'EDITOR\' && (\n                      <div className=\"flex items-center gap-1 opacity-60 group-hover:opacity-100 transition-opacity\">\n                        <button\n                          onClick={() => handleOpenEdit(item)}\n                          className=\"p-1 text-slate-400 hover:text-primary rounded hover:bg-slate-50 transition-colors\"\n                          title=\"S\341\273\255a\"\n                        >\n                          <FileEdit className=\"w-3.5 h-3.5\" />\n                        </button>\n                        <button\n                          onClick={() => handleDelete(item.id)}\n                          className=\"p-1 text-slate-400 hover:text-red-500 rounded hover:bg-slate-50 transition-colors\"\n                          title=\"X\303\263a\"\n                        >\n                          <Trash2 className=\"w-3.5 h-3.5\" />\n                        </button>\n                      </div>\n                    )}\n                  </div>\n                </div>\n\n                <h4 className=\"text-sm font-extrabold text-slate-800 mb-2 leading-snug\">{item.title}</h4>\n                <p className=\"text-xs text-slate-600 leading-relaxed mb-4\">{item.description}</p>\n              </div>\n\n              {item.indicator && (\n                <div className=\"bg-slate-50 p-3.5 rounded-xl border border-slate-100 mt-2\">\n                  <div className=\"flex items-center gap-1.5 mb-1.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider\">\n                    <Award className=\"w-3.5 h-3.5 text-amber-500 shrink-0\" />\n                    <span>Ch\341\273\211 s\341\273\221 ki\341\273\203m so\303\241t ch\341\272\245t l\306\260\341\273\243ng (KPI)</span>\n                  </div>\n                  <p className=\"text-xs text-slate-600 italic\">\342\200\234{item.indicator}\342\200\235</p>\n                </div>\n              )}\n            </div>\n          ))\n        )}\n      </div>\n\n      {/* Tech info notice banner */}\n      <div className=\"bg-blue-50/50 p-5 rounded-2xl border border-blue-100 flex gap-3 items-start\">\n        <Info className=\"w-5 h-5 text-indigo-600 shrink-0 mt-0.5\" />\n        <div>\n          <span className=\"text-xs font-bold text-indigo-900 block uppercase tracking-tight\">Quy t\304\203c Th\341\272\251m \304\221\341\273\213nh v\303\240 \304\220\341\273\223ng b\341\273\231 s\341\273\221 li\341\273\207u</span>\n          <p className=\"text-xs text-slate-600 leading-relaxed mt-1\">\n            Danh m\341\273\245c b\341\273\231 ch\341\273\211 ti\303\252u \304\221\306\260\341\273\243c ban h\303\240nh ch\303\255nh th\341\273\251c c\341\272\245p T\341\273\211nh v\303\240 \304\221\341\273\223ng b\341\273\231 t\341\273\261 \304\221\341\273\231ng xu\341\273\221ng to\303\240n b\341\273\231 45 x\303\243 c\341\273\247a \304\220\306\241n v\341\273\213. M\341\273\215i s\341\273\255a \304\221\341\273\225i, x\303\263a ho\341\272\267c t\341\272\241o m\341\273\233i ch\341\273\211 c\303\263 hi\341\273\207u l\341\273\261c ph\303\241p l\303\275 khi \304\221\306\260\341\273\243c C\303\241n b\341\273\231 qu\341\272\243n tr\341\273\213 T\341\273\211nh ph\303\252 chu\341\272\251n v\303\240 \341\272\245n k\303\275 s\341\273\221 \304\221i\341\273\207n t\341\273\255.\n          </p>\n        </div>\n      </div>\n\n      {/* ADD MODAL */}\n      {showAddModal && (\n        <div className=\"fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center z-50 p-4\">\n          <div className=\"bg-white rounded-2xl max-w-md w-full p-6 shadow-2xl border border-slate-100 animate-slide-up\">\n            <div className=\"flex justify-between items-start mb-4\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"p-2 bg-indigo-50 text-indigo-600 rounded-lg\">\n                  <FileText className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"text-sm font-extrabold text-slate-900 font-sans\">Th\303\252m ti\303\252u ch\303\255 m\341\273\233i</h4>\n                  <p className=\"text-[10px] text-secondary\">Th\303\252m ch\341\273\211 chu\341\272\251n v\303\240o S\341\273\225 tay h\306\260\341\273\233ng d\341\272\253n Qu\341\273\221c gia</p>\n                </div>\n              </div>\n              <button onClick={() => setShowAddModal(false)} className=\"text-slate-400 hover:text-slate-700\">\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            <form onSubmit={handleCreate} className=\"space-y-4 font-sans\">\n              <div className=\"grid grid-cols-3 gap-3\">\n                <div className=\"col-span-1\">\n                  <label className=\"text-xs font-bold text-slate-700 block mb-1\">M\303\243 s\341\273\221</label>\n                  <input\n                    type=\"text\"\n                    required\n                    value={cCode}\n                    onChange={(e) => setCCode(e.target.value)}\n                    placeholder=\"TC-11\"\n                    className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold text-slate-800 text-center\"\n                  />\n                </div>\n                <div className=\"col-span-2\">\n                  <label className=\"text-xs font-bold text-slate-700 block mb-1\">Tr\341\273\215ng s\341\273\221 (%)</label>\n                  <input\n                    type=\"text\"\n                    required\n                    value={cWeight}\n                    onChange={(e) => setCWeight(e.target.value)}\n                    placeholder=\"10%\"\n                    className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold text-slate-800\"\n                  />\n                </div>\n              </div>\n\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1\">T\303\252n ti\303\252u ch\303\255</label>\n                <input\n                  type=\"text\"\n                  required\n                  value={cTitle}\n                  onChange={(e) => setCTitle(e.target.value)}\n                  placeholder=\"V\303\255 d\341\273\245: H\341\272\241 t\341\272\247ng n\303\264ng th\303\264n s\341\273\221 v\303\240 b\306\260u ch\303\255nh\"\n                  className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold text-slate-800\"\n                />\n              </div>\n\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1\">M\303\264 t\341\272\243 m\341\273\245c ti\303\252u</label>\n                <textarea\n                  rows={3}\n                  value={cDesc}\n                  onChange={(e) => setCDesc(e.target.value)}\n                  placeholder=\"M\303\264 t\341\272\243 c\341\273\245 th\341\273\203 c\303\241c y\303\252u c\341\272\247u ho\341\272\267c t\341\273\267 l\341\273\207 \304\221\341\272\241t chu\341\272\251n x\303\242y d\341\273\261ng...\"\n                  className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none text-slate-700\"\n                />\n              </div>\n\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1\">Ch\341\273\211 s\341\273\221 \304\221o l\306\260\341\273\235ng ch\303\255nh (KPI)</label>\n                <input\n                  type=\"text\"\n                  value={cIndicator}\n                  onChange={(e) => setCIndicator(e.target.value)}\n                  placeholder=\"V\303\255 d\341\273\245: T\341\273\267 l\341\273\207 x\303\243 \304\221\341\272\241t ph\341\273\247 m\341\272\241ng b\304\203ng th\303\264ng \304\221\341\272\241t tr\303\252n 95%\"\n                  className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none text-slate-700\"\n                />\n              </div>\n\n              <div className=\"flex gap-3 pt-2\">\n                <button\n                  type=\"button\"\n                  onClick={() => setShowAddModal(false)}\n                  className=\"flex-1 py-2.5 border border-slate-300 text-slate-600 text-xs font-bold rounded-lg hover:bg-slate-50\"\n                >\n                  H\341\273\247y b\341\273\217\n                </button>\n                <button\n                  type=\"submit\"\n                  className=\"flex-1 py-2.5 bg-primary text-white text-xs font-bold rounded-lg hover:bg-primary-container shadow-md\"\n                >\n                  Th\303\252m ti\303\252u ch\303\255\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n\n      {/* EDIT MODAL */}\n      {showEditModal && (\n        <div className=\"fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center z-50 p-4\">\n          <div className=\"bg-white rounded-2xl max-w-md w-full p-6 shadow-2xl border border-slate-100 animate-slide-up\">\n            <div className=\"flex justify-between items-start mb-4\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"p-2 bg-indigo-50 text-indigo-600 rounded-lg\">\n                  <FileEdit className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"text-sm font-extrabold text-slate-900 font-sans\">Hi\341\273\207u ch\341\273\211nh ti\303\252u ch\303\255</h4>\n                  <p className=\"text-[10px] text-secondary\">C\341\272\255p nh\341\272\255t ch\341\273\211 chu\341\272\251n chu\341\272\251n m\341\273\261c Qu\341\273\221c gia</p>\n                </div>\n              </div>\n              <button onClick={() => setShowEditModal(false)} className=\"text-slate-400 hover:text-slate-700\">\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            <form onSubmit={handleSaveEdit} className=\"space-y-4 font-sans\">\n              <div className=\"grid grid-cols-3 gap-3\">\n                <div className=\"col-span-1\">\n                  <label className=\"text-xs font-bold text-slate-700 block mb-1\">M\303\243 s\341\273\221</label>\n                  <input\n                    type=\"text\"\n                    required\n                    value={cCode}\n                    onChange={(e) => setCCode(e.target.value)}\n                    className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold text-slate-800 text-center\"\n                  />\n                </div>\n                <div className=\"col-span-2\">\n                  <label className=\"text-xs font-bold text-slate-700 block mb-1\">Tr\341\273\215ng s\341\273\221 (%)</label>\n                  <input\n                    type=\"text\"\n                    required\n                    value={cWeight}\n                    onChange={(e) => setCWeight(e.target.value)}\n                    className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold text-slate-800\"\n                  />\n                </div>\n              </div>\n\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1\">T\303\252n ti\303\252u ch\303\255</label>\n                <input\n                  type=\"text\"\n                  required\n                  value={cTitle}\n                  onChange={(e) => setCTitle(e.target.value)}\n                  className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none font-semibold text-slate-800\"\n                />\n              </div>\n\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1\">M\303\264 t\341\272\243 m\341\273\245c ti\303\252u</label>\n                <textarea\n                  rows={3}\n                  value={cDesc}\n                  onChange={(e) => setCDesc(e.target.value)}\n                  className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none text-slate-700\"\n                />\n              </div>\n\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1\">Ch\341\273\211 s\341\273\221 \304\221o l\306\260\341\273\235ng ch\303\255nh (KPI)</label>\n                <input\n                  type=\"text\"\n                  value={cIndicator}\n                  onChange={(e) => setCIndicator(e.target.value)}\n                  className=\"w-full text-xs p-2.5 bg-slate-50 border border-slate-300 rounded-lg outline-none text-slate-700\"\n                />\n              </div>\n\n              <div className=\"flex gap-3 pt-2\">\n                <button\n                  type=\"button\"\n                  onClick={() => setShowEditModal(false)}\n                  className=\"flex-1 py-2.5 border border-slate-300 text-slate-600 text-xs font-bold rounded-lg hover:bg-slate-50\"\n                >\n                  H\341\273\247y b\341\273\217\n                </button>\n                <button\n                  type=\"submit\"\n                  className=\"flex-1 py-2.5 bg-primary text-white text-xs font-bold rounded-lg hover:bg-primary-container shadow-md\"\n                >\n                  L\306\260u thay \304\221\341\273\225i\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
    }
