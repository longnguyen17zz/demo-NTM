        }
        lines {
          text: "                </p>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "              </div>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "              <div className=\"space-y-1.5\">"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                <span className=\"font-bold text-slate-800 uppercase text-[11px] block text-primary\">2. C\306\241 ch\341\272\277 t\341\273\261 \304\221\341\273\231ng b\303\271 l\341\272\245p \"K\341\272\277 ho\341\272\241ch 6 th\303\241ng cu\341\273\221i n\304\203m\"</span>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                <p>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                  Ch\341\273\211 ti\303\252u cu\341\273\221i n\304\203m do c\303\241c ph\303\262ng ban ch\341\273\251c n\304\203ng ho\341\272\241ch \304\221\341\273\213nh. C\303\241c \303\264 nh\341\272\255p li\341\273\207u c\303\263 m\303\240u \303\241nh xanh nh\341\272\271 bi\341\273\203u tr\306\260ng cho c\303\241c c\341\273\231t d\341\273\257 li\341\273\207u li\303\252n quan m\341\272\255t thi\341\272\277t \304\221\341\272\277n ti\341\272\277n \304\221\341\273\231 gi\341\272\243i ng\303\242n x\303\242y d\341\273\261ng c\306\241 b\341\272\243n."
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                </p>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
