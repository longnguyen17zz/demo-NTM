        lines {
          text: "    id: 4,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    title: \"Ti\303\252u ch\303\255 4: \304\220i\341\273\207n n\303\264ng th\303\264n\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    description: \"H\341\273\207 th\341\273\221ng \304\221i\341\273\207n \304\221\341\272\241t chu\341\272\251n k\341\273\271 thu\341\272\255t c\341\273\247a ng\303\240nh \304\221i\341\273\207n. T\341\273\267 l\341\273\207 h\341\273\231 s\341\273\255 d\341\273\245ng \304\221i\341\273\207n th\306\260\341\273\235ng xuy\303\252n, an to\303\240n t\341\273\253 c\303\241c ngu\341\273\223n \304\221\341\272\241t t\341\273\253 98% tr\341\273\237 l\303\252n.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    indicator: \"Ngu\341\273\223n cung c\341\272\245p \304\221i\341\273\207n \341\273\225n \304\221\341\273\213nh, h\341\272\241 t\341\272\247ng \304\221i\341\273\207n n\303\264ng th\303\264n \304\221\341\272\243m b\341\272\243o ph\303\262ng ch\341\273\221ng ch\303\241y n\341\273\225.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    weight: \"5%\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
