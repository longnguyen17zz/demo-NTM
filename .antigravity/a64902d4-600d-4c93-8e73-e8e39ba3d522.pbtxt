        lines {
          text: "    title: \"Ti\303\252u ch\303\255 8: Th\303\264ng tin v\303\240 Truy\341\273\201n th\303\264ng\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    description: \"X\303\243 c\303\263 \304\221i\341\273\203m ph\341\273\245c v\341\273\245 b\306\260u ch\303\255nh vi\341\273\205n th\303\264ng c\303\263 Internet t\341\273\221c \304\221\341\273\231 cao. C\303\263 \304\221\303\240i truy\341\273\201n thanh ph\303\241t thanh \304\221\341\272\277n to\303\240n b\341\273\231 c\303\241c khu d\303\242n c\306\260.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    indicator: \"C\303\263 \341\273\251ng d\341\273\245ng c\303\264ng ngh\341\273\207 th\303\264ng tin trong gi\341\272\243i quy\341\272\277t d\341\273\213ch v\341\273\245 c\303\264ng c\341\272\245p x\303\243.\","
