        lines {
          text: "  { id: \"c7\", code: \"TC-07\", title: \"C\306\241 s\341\273\237 h\341\272\241 t\341\272\247ng th\306\260\306\241ng m\341\272\241i n\303\264ng th\303\264n\", description: \"Ch\341\273\243 ho\341\272\267c trung t\303\242m mua s\341\272\257m \304\221\341\272\241t chu\341\272\251n v\341\273\207 sinh th\341\273\261c ph\341\272\251m.\", indicator: \"Ch\341\273\243 \304\221\341\272\241t chu\341\272\251n trung b\303\254nh t\341\273\253 80%\", weight: \"5%\" },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  { id: \"c8\", code: \"TC-08\", title: \"Th\303\264ng tin v\303\240 truy\341\273\201n th\303\264ng s\341\273\221 c\341\272\245p x\303\243\", description: \"Internet t\341\273\221c \304\221\341\273\231 cao v\303\240 \341\273\251ng d\341\273\245ng c\341\273\225ng d\341\273\213ch v\341\273\245 c\303\264ng tr\341\273\261c tuy\341\272\277n.\", indicator: \"Loa th\303\264ng minh \304\221\341\272\241t chu\341\272\251n 100% th\303\264n\", weight: \"10%\" },"
