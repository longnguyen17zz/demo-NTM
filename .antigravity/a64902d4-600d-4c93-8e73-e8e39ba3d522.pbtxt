        lines {
          text: "  { id: \"c5\", code: \"TC-05\", title: \"Tr\306\260\341\273\235ng h\341\273\215c v\303\240 v\341\272\255t ch\341\272\245t gi\303\241o d\341\273\245c qu\341\273\221c gia\", description: \"C\303\241c c\341\272\245p h\341\273\215c c\303\263 c\306\241 s\341\273\237 \304\221\341\272\241t chu\341\272\251n qu\341\273\221c gia theo quy \304\221\341\273\213nh.\", indicator: \"C\306\241 s\341\273\237 d\341\272\241y h\341\273\215c \304\221\341\272\241t chu\341\272\251n tr\303\252n 75%\", weight: \"12%\" },"
