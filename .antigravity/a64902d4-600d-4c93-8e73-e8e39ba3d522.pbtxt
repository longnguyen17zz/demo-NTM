    replacement_chunks {
      target_content: "  return (\n    <div className=\"space-y-6 animate-fade-in text-slate-800 font-sans\">\n      {/* Subheader and Controls */}\n      <div className=\"bg-white p-6 rounded-2xl border border-surface-border shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4\">\n        <div>\n          <h3 className=\"text-sm font-bold text-slate-800 uppercase tracking-tight flex items-center gap-1.5\">\n            <BookmarkCheck className=\"w-5 h-5 text-primary\" />\n            <span>S\341\273\225 tay H\306\260\341\273\233ng d\341\272\253n \304\221\303\241nh gi\303\241 b\341\273\231 ti\303\252u th\341\272\277 Qu\341\273\221c gia</span>\n          </h3>\n          <p className=\"text-xs text-secondary mt-1\">\n            Tra c\341\273\251u v\303\240 c\341\272\245u h\303\254nh danh m\341\273\245c b\341\273\231 ti\303\252u ch\303\255 N\303\264ng th\303\264n m\341\273\233i giai \304\221o\341\272\241n 2021 - 2025\n          </p>\n        </div>\n\n        <div className=\"flex items-center gap-3 w-full md:w-auto\">\n          <div className=\"relative flex-1 md:w-64\">\n            <input\n              type=\"text\"\n              value={searchTerm}\n              onChange={(e) => setSearchTerm(e.target.value)}\n              placeholder=\"T\303\254m nhanh ti\303\252u ch\303\255...\"\n              className=\"w-full pl-9 pr-4 py-2.5 bg-slate-50 border border-slate-200 focus:border-primary rounded-xl text-xs outline-none transition-all focus:ring-2 focus:ring-primary/10\"\n            />\n            <Search className=\"w-4 h-4 text-slate-400 absolute left-3.5 top-1/2 -translate-y-1/2\" />\n          </div>\n\n          {userSession.role === \'EDITOR\' && (\n            <button\n              onClick={handleOpenAdd}\n              className=\"px-4 py-2.5 bg-primary text-white hover:bg-primary-container text-xs font-bold rounded-xl flex items-center gap-1.5 shrink-0 transition-all cursor-pointer\"\n            >\n              <PlusCircle className=\"w-4 h-4\" />\n              <span>Th\303\252m ti\303\252u ch\303\255</span>\n            </button>\n          )}\n        </div>\n      </div>\n\n      {/* Grid of Criteria cards */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n        {filteredCriteria.length === 0 ? (\n          <div className=\"md:col-span-2 text-center p-12 bg-white rounded-2xl border border-dashed border-slate-300\">\n            <BookOpen className=\"w-12 h-12 text-slate-300 mx-auto mb-3\" />\n            <p className=\"text-sm text-secondary font-medium\">Kh\303\264ng t\303\254m th\341\272\245y ti\303\252u ch\303\255 n\303\240o ph\303\271 h\341\273\243p</p>\n          </div>\n        ) : (\n          filteredCriteria.map((item) => (\n            <div\n              key={item.id}\n              className=\"bg-white p-6 rounded-2xl border border-surface-border shadow-sm flex flex-col justify-between hover:border-primary/40 hover:shadow-md transition-all duration-200 relative group\"\n            >\n              <div>\n                <div className=\"flex items-center justify-between mb-3 border-b border-slate-50 pb-2\">\n                  <span className=\"text-[10px] font-bold text-primary bg-indigo-50 px-3 py-1 rounded-full uppercase tracking-tight\">\n                    {item.code}\n                  </span>\n                  <div className=\"flex items-center gap-2\">\n                    <div className=\"flex items-center gap-1 text-[10px] bg-slate-100 text-slate-600 px-2 py-0.5 rounded font-mono\">\n                      <Weight className=\"w-3.5 h-3.5 text-secondary\" />\n                      <span>Tr\341\273\215ng s\341\273\221: {item.weight}</span>\n                    </div>\n\n                    {userSession.role === \'EDITOR\' && (\n                      <div className=\"flex items-center gap-1 opacity-60 group-hover:opacity-100 transition-opacity\">\n                        <button\n                          onClick={() => handleOpenEdit(item)}\n                          className=\"p-1 text-slate-400 hover:text-primary rounded hover:bg-slate-50 transition-colors\"\n                          title=\"S\341\273\255a\"\n                        >\n                          <FileEdit className=\"w-3.5 h-3.5\" />\n                        </button>\n                        <button\n                          onClick={() => handleDelete(item.id)}\n                          className=\"p-1 text-slate-400 hover:text-red-500 rounded hover:bg-slate-50 transition-colors\"\n                          title=\"X\303\263a\"\n                        >\n                          <Trash2 className=\"w-3.5 h-3.5\" />\n                        </button>\n                      </div>\n                    )}\n                  </div>\n                </div>\n\n                <h4 className=\"text-sm font-extrabold text-slate-800 mb-2 leading-snug\">{item.title}</h4>\n                <p className=\"text-xs text-slate-600 leading-relaxed mb-4\">{item.description}</p>\n              </div>\n\n              {item.indicator && (\n                <div className=\"bg-slate-50 p-3.5 rounded-xl border border-slate-100 mt-2\">\n                  <div className=\"flex items-center gap-1.5 mb-1.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider\">\n                    <Award className=\"w-3.5 h-3.5 text-amber-500 shrink-0\" />\n                    <span>Ch\341\273\211 s\341\273\221 ki\341\273\203m so\303\241t ch\341\272\245t l\306\260\341\273\243ng (KPI)</span>\n                  </div>\n                  <p className=\"text-xs text-slate-600 italic\">\342\200\234{item.indicator}\342\200\235</p>\n                </div>\n              )}\n            </div>\n          ))\n        )}\n      </div>\n\n      {/* Tech info notice banner */}\n      <div className=\"bg-blue-50/50 p-5 rounded-2xl border border-blue-100 flex gap-3 items-start\">\n        <Info className=\"w-5 h-5 text-indigo-600 shrink-0 mt-0.5\" />\n        <div>\n          <span className=\"text-xs font-bold text-indigo-900 block uppercase tracking-tight\">Quy t\304\203c Th\341\272\251m \304\221\341\273\213nh v\303\240 \304\220\341\273\223ng b\341\273\231 s\341\273\221 li\341\273\207u</span>\n          <p className=\"text-xs text-slate-600 leading-relaxed mt-1\">\n            Danh m\341\273\245c b\341\273\231 ch\341\273\211 ti\303\252u \304\221\306\260\341\273\243c ban h\303\240nh ch\303\255nh th\341\273\251c c\341\272\245p T\341\273\211nh v\303\240 \304\221\341\273\223ng b\341\273\231 t\341\273\261 \304\221\341\273\231ng xu\341\273\221ng to\303\240n b\341\273\231 45 x\303\243 c\341\273\247a \304\220\306\241n v\341\273\213. M\341\273\215i s\341\273\255a \304\221\341\273\225i, x\303\263a ho\341\272\267c t\341\272\241o m\341\273\233i ch\341\273\211 c\303\263 hi\341\273\207u l\341\273\261c ph\303\241p l\303\275 khi \304\221\306\260\341\273\243c C\303\241n b\341\273\231 qu\341\272\243n tr\341\273\213 T\341\273\211nh ph\303\252 chu\341\272\251n v\303\240 \341\272\245n k\303\275 s\341\273\221 \304\221i\341\273\207n t\341\273\255.\n          </p>\n        </div>\n      </div>"
      replacement_content: "  return (\n    <div className=\"space-y-8 animate-fade-in text-slate-800 font-sans\">\n      {/* Subheader and Controls */}\n      <div className=\"bg-white p-6 rounded-3xl border border-slate-100 shadow-[0_4px_25px_rgba(0,0,0,0.012)] flex flex-col md:flex-row md:items-center justify-between gap-5\">\n        <div>\n          <h3 className=\"text-sm font-black text-slate-900 uppercase tracking-wider flex items-center gap-2\">\n            <BookmarkCheck className=\"w-5 h-5 text-amber-500\" />\n            <span>S\341\273\225 tay H\306\260\341\273\233ng d\341\272\253n \304\221\303\241nh gi\303\241 b\341\273\231 ch\341\273\211 ti\303\252u Qu\341\273\221c gia</span>\n          </h3>\n          <p className=\"text-xs text-slate-400 font-bold mt-1\">\n            Tra c\341\273\251u th\303\264ng tin gi\341\272\243i quy\341\272\277t nghi\341\273\207p v\341\273\245 v\303\240 \304\221\341\273\223ng b\341\273\231 danh m\341\273\245c \304\220\341\273\207 nh\341\272\245t ti\303\252u chu\341\272\251n n\303\264ng th\303\264n m\341\273\233i Vi\341\273\207t Nam\n          </p>\n        </div>\n\n        <div className=\"flex items-center gap-3 w-full md:w-auto justify-end\">\n          <div className=\"relative flex-1 md:w-64\">\n            <input\n              type=\"text\"\n              value={searchTerm}\n              onChange={(e) => setSearchTerm(e.target.value)}\n              placeholder=\"Tra c\341\273\251u t\303\252n ho\341\272\267c m\303\243 ti\303\252u ch\303\255...\"\n              className=\"w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 focus:border-slate-400 rounded-xl text-xs font-bold outline-none transition-all focus:ring-4 focus:ring-slate-100 placeholder:text-slate-400\"\n            />\n            <Search className=\"w-4 h-4 text-slate-400 absolute left-3.5 top-1/2 -translate-y-1/2\" />\n          </div>\n\n          {userSession.role === \'EDITOR\' && (\n            <button\n              onClick={handleOpenAdd}\n              className=\"px-5 py-2.5 bg-slate-900 text-white hover:bg-slate-800 text-xs font-black uppercase tracking-wider rounded-xl flex items-center gap-2 shrink-0 transition-all cursor-pointer shadow-md shadow-slate-950/10\"\n            >\n              <PlusCircle className=\"w-4 h-4 text-amber-500\" />\n              <span>Th\303\252m ti\303\252u ch\303\255</span>\n            </button>\n          )}\n        </div>\n      </div>\n\n      {/* Grid of Criteria cards */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n        {filteredCriteria.length === 0 ? (\n          <div className=\"md:col-span-2 text-center p-16 bg-white rounded-3xl border border-dashed border-slate-200\">\n            <BookOpen className=\"w-12 h-12 text-slate-300 mx-auto mb-4\" />\n            <p className=\"text-sm text-slate-400 font-black uppercase tracking-wider\">Kh\303\264ng t\303\254m th\341\272\245y ti\303\252u ch\303\255 kh\341\272\243 d\341\273\245ng</p>\n          </div>\n        ) : (\n          filteredCriteria.map((item) => (\n            <div\n              key={item.id}\n              className=\"bg-white p-6 rounded-3xl border border-slate-100 shadow-[0_4px_25px_rgba(0,0,0,0.015)] flex flex-col justify-between hover:border-amber-500/30 hover:shadow-[0_12px_30px_rgba(0,0,0,0.035)] transition-all duration-300 relative group\"\n            >\n              <div>\n                <div className=\"flex items-center justify-between mb-4 border-b border-slate-50 pb-3\">\n                  <span className=\"text-[10px] font-black text-slate-800 bg-slate-100 border border-slate-200/60 px-3.5 py-1.5 rounded-lg uppercase tracking-widest\">\n                    {item.code}\n                  </span>\n                  <div className=\"flex items-center gap-2\">\n                    <div className=\"flex items-center gap-1.5 text-[9px] bg-amber-500/10 text-amber-800 border border-amber-500/10 px-2.5 py-1 rounded-full uppercase font-black tracking-wider\">\n                      <Weight className=\"w-3.5 h-3.5 text-amber-600\" />\n                      <span>Tr\341\273\215ng s\341\273\221: {item.weight}</span>\n                    </div>\n\n                    {userSession.role === \'EDITOR\' && (\n                      <div className=\"flex items-center gap-1 opacity-40 group-hover:opacity-100 transition-opacity\">\n                        <button\n                          onClick={() => handleOpenEdit(item)}\n                          className=\"p-1 px-1.5 text-slate-400 hover:text-indigo-600 hover:bg-slate-50 rounded-lg transition-colors\"\n                          title=\"Ch\341\273\211nh s\341\273\255a\"\n                        >\n                          <FileEdit className=\"w-4 h-4\" />\n                        </button>\n                        <button\n                          onClick={() => handleDelete(item.id)}\n                          className=\"p-1 px-1.5 text-slate-400 hover:text-red-500 hover:bg-slate-50 rounded-lg transition-colors\"\n                          title=\"H\341\273\247y b\341\273\217\"\n                        >\n                          <Trash2 className=\"w-4 h-4\" />\n                        </button>\n                      </div>\n                    )}\n                  </div>\n                </div>\n\n                <h4 className=\"text-sm font-black text-slate-900 mb-2 leading-relaxed uppercase tracking-wide\">{item.title}</h4>\n                <p className=\"text-xs text-slate-500 leading-relaxed font-bold mb-5\">{item.description}</p>\n              </div>\n\n              {item.indicator && (\n                <div className=\"bg-slate-50/55 p-4 rounded-2xl border border-slate-100 mt-2\">\n                  <div className=\"flex items-center gap-1.5 mb-2 text-[9px] font-black text-slate-400 uppercase tracking-widest\">\n                    <Award className=\"w-3.5 h-3.5 text-amber-500 shrink-0\" />\n                    <span>H\341\272\241n \304\221\341\273\213nh ch\341\2