        }
        lines {
          text: "export const INITIAL_DICTIONARY_CRITERIA = ["
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  { id: \"c1\", code: \"TC-01\", title: \"Quy ho\341\272\241ch x\303\242y d\341\273\261ng x\303\243 n\303\264ng th\303\264n m\341\273\233i\", description: \"C\303\263 quy ho\341\272\241ch chung \304\221\306\260\341\273\243c ph\303\252 duy\341\273\207t v\303\240 qu\341\272\243n l\303\275 \304\221\303\272ng quy \304\221\341\273\213nh.\", indicator: \"T\341\273\267 l\341\273\207 quy ho\341\272\241ch \304\221\341\272\241t chu\341\272\251n 100%\", weight: \"10%\" },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
