\341\272\241 t\341\272\247ng k\341\273\271 thu\341\272\255t v\303\240 giao th\303\264ng li\303\252n x\303\243\" },\n  { code: \"Bi\341\273\203u 06\", title: \"Bi\341\273\203u th\341\273\221ng k\303\252 c\306\241 s\341\273\237 th\341\273\247y l\341\273\243i, ph\303\262ng ch\341\273\221ng thi\303\252n tai\" },\n  { code: \"Bi\341\273\203u 07\", title: \"Bi\341\273\203u theo d\303\265i l\306\260\341\273\233i \304\221i\341\273\207n v\303\240 ph\303\242n ph\341\273\221i \304\221i\341\273\207n n\303\264ng th\303\264n\" },\n  { code: \"Bi\341\273\203u 08\", title: \"Bi\341\273\203u t\341\273\225ng k\341\272\277t v\341\272\255t ch\341\272\245t gi\303\241o d\341\273\245c v\303\240 \304\221\303\240o t\341\272\241o n\303\264ng nghi\341\273\207p\" },\n  { code: \"Bi\341\273\203u 09\", title: \"Bi\341\273\203u ki\341\273\203m so\303\241t nh\303\240 v\304\203n h\303\263a, thi\341\272\277t ch\341\272\277 th\341\273\203 thao th\303\264n b\341\272\243n\" },\n  { code: \"Bi\341\273\203u 10\", title: \"Bi\341\273\203u r\303\240 so\303\241t ch\341\273\243, chu\341\273\227i th\306\260\306\241ng m\341\272\241i v\303\240 b\303\241n l\341\272\273 n\303\264ng th\303\264n\" },\n  { code: \"Bi\341\273\203u 11\", title: \"Bi\341\273\203u c\341\272\255p nh\341\272\255t h\341\272\241 t\341\272\247ng s\341\273\221, internet v\303\240 chuy\341\273\203n \304\221\341\273\225i c\303\264ng ngh\341\273\207\" },\n  { code: \"Bi\341\273\203u 12\", title: \"Bi\341\273\203u th\341\272\251m \304\221\341\273\213nh x\303\263a nh\303\240 d\341\273\231t n\303\241t, n\303\242ng c\341\272\245p nh\303\240 ki\303\252n c\341\273\221\" },\n  { code: \"Bi\341\273\203u 13\", title: \"Bi\341\273\203u t\341\273\225ng h\341\273\243p t\304\203ng tr\306\260\341\273\237ng thu nh\341\272\255p, x\303\263a ngh\303\250o \304\221a chi\341\273\201u\" }\n];\n\nimport { ReportPeriod, FormReport, CriterionRow } from \'./types\';\n\nexport function createDefaultFormsForPeriod(periodId: string, customCategories?: string[]): FormReport[] {\n  // Use INITIAL_CRITERIA_ROWS as base data\n  return FORM_METAS.map((meta, index) => {\n    // Generate slight variances in criteria values for high-fidelity realism\n    const customizedData: CriterionRow[] = INITIAL_CRITERIA_ROWS.map((row) => {\n      const modifier = (index + row.id) % 3;\n      return {\n        ...row,\n        group1: {\n          prevYear: Math.max(2, row.group1.prevYear - modifier),\n          currentS1: Math.max(3, row.group1.currentS1 - modifier),\n          planS2: Math.max(4, row.group1.planS2 - modifier)\n        },\n        group2: {\n          prevYear: Math.max(1, row.group2.prevYear - modifier),\n          currentS1: Math.max(2, row.group2.currentS1 - modifier),\n          planS2: Math.max(3, row.group2.planS2 - modifier)\n        },\n        group3: {\n          prevYear: Math.max(0, row.group3.prevYear - modifier),\n          currentS1: Math.max(1, row.group3.currentS1 - modifier),\n          planS2: Math.max(2, row.group3.planS2 - modifier)\n        }\n      };\n    });\n\n    // Preset some statuses for the 1st period to make it interesting\n    let status: \'DRAFT\' | \'SUBMITTED\' | \'APPROVED\' | \'SUPERVISED\' = \'DRAFT\';\n    if (periodId === \'2024-6tdu\') {\n      if (index === 0) status = \'SUPERVISED\';\n      else if (index === 1) status = \'APPROVED\';\n      else if (index === 2) status = \'SUBMITTED\';\n    }\n\n    const proofFiles = status !== \'DRAFT\' ? [\n      { name: `BieuMau_${meta.code.replace(\' \', \'\')}_ChungThucS\341\273\221.pdf`, size: 2400100 + index * 15000, uploadedAt: \'2026-05-18\', type: \'pdf\' }\n    ] : [];\n\n    // Attach mock logs if status is advanced\n    const appraisal = status === \'APPROVED\' || status === \'SUPERVISED\' ? {\n      appraiserName: \'Tr\341\272\247n Minh Th\341\272\251m\',\n      comment: `S\341\273\221 li\341\273\207u c\341\273\247a ${meta.code} kh\341\273\233p v\341\273\233i c\306\241 s\341\273\237 d\341\273\257 li\341\273\207u th\341\273\261c \304\221\341\273\213a. \304\220\341\272\241t chu\341\272\251n k\341\273\271 thu\341\272\255t li\303\252n ng\303\240nh.`,\n      updatedAt: \'2026-05-19T08:30:00Z\',\n      decision: \'APPROVED\' as const\n    } : undefined;\n\n    const supervision = status === \'SUPERVISED\' ? {\n      supervisorName: \'Ph\341\272\241m Ho\303\240ng Gi\303\241m\',\n      comment: \'H\341\273\223 s\306\241 \304\221\303\243 ki\341\273\203m to\303\241n ch\303\251o qua \341\272\243nh v\341\273\207 tinh v\303\240 kh\341\272\243o s\303\241t th\341\273\261c \304\221\341\273\213a. Tr\341\272\241ng th\303\241i \304\221\341\272\241t y\303\252u c\341\272\247u th\341\273\261c t\341\272\277.\',\n      updatedAt: \'2026-05-20T04:15:00Z\',\n      complianceLevel: \'Xu\341\272\245t s\341\272\257c\'\n    } : undefined;\n\n    return {\n      id: `${periodId}-${meta.code.toLowerCase().replace(\' \', \'\')}`,\n      code: meta.code,\n      title: meta.title,\n      status,\n      updatedAt: \'2026-05-20T03:00:00Z\',\n      editor: status !== \'DRAFT\' ? \'Nguy\341\273\205n V\304\203n An\' : \'\',\n      proofFiles,\n      data: customizedData,\n      appraisal,\n      supervision\n    };\n  });\n}\n\nexport const INITIAL_PERIODS: ReportPeriod[] = [\n  {\n    id: \"2024-6tdu\",\n    name: \"\304\220\341\273\243t b\303\241o c\303\241o NTM 6 th\303\241ng \304\221\341\272\247u n\304\203m 2024\",\n    year: \"2024\",\n    term: \"6 th\303\241ng \304\221\341\272\247u n\304\203m\",\n    deadline: \"2024-06-30\",\n    forms: [] // will be initialized on start\n  },\n  {\n    id: \"2024-canham\",\n    name: \"\304\220\341\273\243t b\303\241o c\303\241o NTM c\341\272\243 n\304\203m 2024\",\n    year: \"2024\",\n    term: \"To\303\240n di\341\273\207n c\341\272\243 n\304\203m\",\n    deadline: \"2024-12-31\",\n    forms: [] // will be initialized on start\n  }\n];\n"
    }
