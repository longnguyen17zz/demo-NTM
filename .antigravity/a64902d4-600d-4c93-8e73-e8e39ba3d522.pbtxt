          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    title: \"Ti\303\252u ch\303\255 9: Nh\303\240 \341\273\237 d\303\242n c\306\260 n\303\264ng th\303\264n\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    description: \"Kh\303\264ng c\303\262n nh\303\240 t\341\272\241m, nh\303\240 d\341\273\231t n\303\241t tr\303\252n \304\221\341\273\213a b\303\240n x\303\243. T\341\273\267 l\341\273\207 h\341\273\231 gia \304\221\303\254nh c\303\263 nh\303\240 \341\273\237 ki\303\252n c\341\273\221 ho\341\272\267c b\303\241n ki\303\252n c\341\273\221 \304\221\341\272\241t t\341\273\253 90% tr\341\273\237 l\303\252n.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    indicator: \"Di\341\273\207n t\303\255ch nh\303\240 \341\273\237 b\303\254nh qu\303\242n \304\221\341\272\247u ng\306\260\341\273\235i \304\221\341\272\241t m\341\273\251c t\341\273\221i thi\341\273\203u 15-20 m2/ng\306\260\341\273\235i.\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    weight: \"15%\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
