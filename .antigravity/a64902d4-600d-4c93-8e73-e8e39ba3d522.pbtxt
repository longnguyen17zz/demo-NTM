    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { ShieldCheck, User, Lock, ArrowRight, Award } from \'lucide-react\';\nimport { UserSession } from \'../types\';\n\ninterface LoginScreenProps {\n  onLoginSuccess: (session: UserSession) => void;\n}\n\nexport default function LoginScreen({ onLoginSuccess }: LoginScreenProps) {\n  const [username, setUsername] = useState(\'canbonhaplieu\');\n  const [password, setPassword] = useState(\'\342\200\242\342\200\242\342\200\242\342\200\242\342\200\242\342\200\242\342\200\242\342\200\242\');\n  const [role, setRole] = useState<\'EDITOR\' | \'APPRAISER\' | \'SUPERVISOR\'>(\'EDITOR\');\n\n  const presetUsers = [\n    {\n      username: \'canbonhaplieu\',\n      fullName: \'Nguy\341\273\205n V\304\203n An\',\n      role: \'EDITOR\' as const,\n      desc: \'C\303\241n b\341\273\231 Chuy\303\252n vi\303\252n x\303\243/huy\341\273\207n (Nh\341\272\255p li\341\273\207u, g\341\273\255i b\303\241o c\303\241o)\',\n    },\n    {\n      username: \'canbotham\304\221inh\',\n      fullName: \'Tr\341\272\247n Minh Th\341\272\251m\',\n      role: \'APPRAISER\' as const,\n      desc: \'Th\303\240nh vi\303\252n H\341\273\231i \304\221\341\273\223ng Th\341\272\251m \304\221\341\273\213nh li\303\252n ng\303\240nh c\341\272\245p T\341\273\211nh\',\n    },\n    {\n      username: \'canbogiamsat\',\n      fullName: \'Ph\341\272\241m Ho\303\240ng Gi\303\241m\',\n      role: \'SUPERVISOR\' as const,\n      desc: \'C\303\241n b\341\273\231 V\304\203n ph\303\262ng Gi\303\241m s\303\241t Trung \306\260\306\241ng &amp; M\341\272\267t tr\341\272\255n T\341\273\225 qu\341\273\221c\',\n    },\n  ];\n\n  const handleSelectPreset = (user: typeof presetUsers[0]) => {\n    setUsername(user.username);\n    setRole(user.role);\n  };\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    const selectedUser = presetUsers.find((u) => u.username === username) || {\n      username: username,\n      fullName: username === \'canbotham\304\221inh\' ? \'Tr\341\272\247n Minh Th\341\272\251m\' : username === \'canbogiamsat\' ? \'Ph\341\272\241m Ho\303\240ng Gi\303\241m\' : \'Nguy\341\273\205n V\304\203n An\',\n      role: role\n    };\n\n    onLoginSuccess({\n      username: selectedUser.username,\n      fullName: selectedUser.fullName,\n      role: selectedUser.role,\n    });\n  };\n\n  return (\n    <div className=\"min-h-screen bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-950 flex flex-col justify-center py-12 sm:px-6 lg:px-8 relative overflow-hidden font-sans\">\n      {/* Decorative ambient blobs */}\n      <div className=\"absolute top-0 left-0 w-96 h-96 bg-primary/10 rounded-full blur-3xl -translate-x-12 -translate-y-12 pointer-events-none\" />\n      <div className=\"absolute bottom-0 right-0 w-96 h-96 bg-emerald-500/5 rounded-full blur-3xl translate-x-12 translate-y-12 pointer-events-none\" />\n\n      {/* Brand Header */}\n      <div className=\"sm:mx-auto sm:w-full sm:max-w-md text-center z-10\">\n        <div className=\"flex justify-center mb-4\">\n          <div className=\"bg-white/10 p-3 rounded-2xl backdrop-blur-md border border-white/20 hover:scale-105 transition-transform duration-300 shadow-xl\">\n            <img\n              alt=\"Vietnam Government Crest\"\n              className=\"w-16 h-16 object-contain\"\n              src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBYgmY9FpFS45i0Rg22DSLm_CMYUB-uUHTPBrMWpWvPe1xUwhroA8JfaWkh-W_XM7c3y72VhadirZt9gpim8wXi9FK9BRd8cwmDi58zJz6SnN-JpO5fRncrb7jHzFDyGDtGeXcHhMdLScsr5EpZRHsCZ0yFEusAQgqReklamTiAI28OjzIZYEuHnfBgb83wAfCowWnfV03DxJanO15wu0QBPpximkjweE5hu6I4dyltsxqAZoTgo_JDPw6Aq4trXgOEooDHPiCpbO0\"\n              referrerPolicy=\"no-referrer\"\n            />\n          </div>\n        </div>\n        <h2 className=\"text-2xl font-extrabold text-white tracking-tight sm:text-3xl leading-snug\">\n          H\341\273\206 TH\341\273\220NG B\303\201O C\303\201O M\341\273\244C TI\303\212U QU\341\273\220C GIA\n        </h2>\n        <p className=\"mt-2 text-sm text-slate-300 max-w-sm mx-auto font-medium\">\n          S\341\273\221 h\303\263a ho\341\272\241t \304\221\341\273\231ng \304\221\303\241nh gi\303\241 th\341\273\261c hi\341\273\207n B\341\273\231 ti\303\252u ch\303\255 Qu\341\273\221c gia x\303\242y d\341\273\261ng <span className=\"text-amber-400 font-bold\">N\303\264ng th\303\264n m\341\273\233i</span>\n        </p>\n      </div>\n\n      <div className=\"mt-8 sm:mx-auto sm:w-full sm:max-w-xl z-10 px-4 sm:px-0\">\n        <div className=\"bg-white/95 rounded-2xl shadow-2xl overflow-hidden border border-white/20 backdrop-blur-md grid grid-cols-1 md:grid-cols-12\">\n          {/* Main Form Fields */}\n          <div className=\"p-8 md:col-span-12 space-y-6\">\n            <div className=\"text-center md:text-left border-b border-slate-100 pb-4\">\n              <h3 className=\"text-base font-extrabold text-slate-800 flex items-center gap-2 justify-center md:justify-start\">\n                <ShieldCheck className=\"w-5 h-5 text-emerald-600\" />\n                <span>X\303\241c th\341\273\261c \304\221\341\272\241i di\341\273\207n t\303\241c v\341\273\245 nghi\341\273\207p v\341\273\245</span>\n              </h3>\n              <p className=\"text-xs text-slate-500 mt-1\">\304\220\304\203ng nh\341\272\255p b\341\272\261ng t\303\240i kho\341\272\243n ho\341\272\267c th\341\273\255 nhanh v\341\273\233i c\303\241c vai tr\303\262 b\303\252n d\306\260\341\273\233i</p>\n            </div>\n\n            <form onSubmit={handleSubmit} className=\"space-y-4\">\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5\">\n                    T\303\252n t\303\240i kho\341\272\243n\n                  </label>\n                  <div className=\"relative\">\n                    <input\n                      type=\"text\"\n                      required\n                      value={username}\n                      onChange={(e) => setUsername(e.target.value)}\n                      className=\"w-full pl-9 pr-3 py-2.5 bg-slate-50 border border-slate-300 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-lg text-xs outline-none font-semibold text-slate-800 transition-all\"\n                    />\n                    <User className=\"w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2\" />\n                  </div>\n                </div>\n\n                <div>\n                  <label className=\"block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5\">\n                    M\341\272\255t kh\341\272\251u truy c\341\272\255p\n                  </label>\n                  <div className=\"relative\">\n                    <input\n                      type=\"password\"\n                      required\n                      value={password}\n                      onChange={(e) => setPassword(e.target.value)}\n                      className=\"w-full pl-9 pr-3 py-2.5 bg-slate-50 border border-slate-300 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-lg text-xs outline-none text-slate-800 transition-all\"\n                    />\n                    <Lock className=\"w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2\" />\n                  </div>\n                </div>\n              </div>\n\n              {/* Quick Role Selection Preset Pills */}\n              <div className=\"space-y-2 pb-2\">\n                <span className=\"block text-xs font-bold text-slate-600\">Ch\341\273\215n nhanh t\303\240i kho\341\272\243n v\303\240 vai tr\303\262 ki\341\273\203m th\341\273\255:</span>\n                <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-2.5\">\n                  {presetUsers.map((p) => {\n                    const isSelected = username === p.username;\n                    return (\n                      <button\n                        key={p.username}\n                        type=\"button\"\n                        onClick={() => handleSelectPreset(p)}\n                        className={`p-3 rounded-xl border text-left cursor-pointer transition-all flex flex-col justify-between ${\n                          isSelected\n                            ? \'border-indigo-600 bg-indigo-50/50 ring-2 ring-indigo-600/10\'\n                            : \'border-slate-200 bg-white hover:border-slate-300 hover:bg-slate-50\'\n                        }`}\n                      >\n                        <span className={`text-xs font-bold ${isSelected ? \'text-indigo-900\' : \'text-slate-800\'}`}>\n                          {p.fullName}\n                        </span>\n                        <span className=\"text-[9px] text-slate-500 mt-1 block font-medium leading-tight\">\n                          {p.desc}\n                        </span>\n                      </button>\n                    );\n                  })}\n                </div>\n              </div>\n\n              <div className=\"pt-2 border-t border-slate-100 flex items-center justify-between gap-4\">\n                <div className=\"flex items-center gap-1.5 text-xs text-slate-500 bg-amber-50 border border-amber-100 p-2 rounded-lg max-w-xs\">\n                  <Award className=\"w-4 h-4 text-amber-500 shrink-0\" />\n                  <span className=\"text-[10px] leading-tight\">M\303\264i tr\306\260\341\273\235ng th\341\273\255 nghi\341\273\207m li\303\252n th\303\264ng Qu\341\273\221c gia - T\341\273\211nh - X\303\243</span>\n                </div>\n                <button\n                  type=\"submit\"\n                  className=\"px-6 py-3 bg-indigo-600 hover:bg-indigo-700 active:scale-95 text-white text-xs font-extrabold rounded-lg flex items-center gap-2 shadow-lg shadow-indigo-600/20 transition-all shrink-0 cursor-pointer\"\n                >\n                  <span>V\303\200O H\341\273\206 TH\341\273\220NG</span>\n                  <ArrowRight className=\"w-4 h-4\" />\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
