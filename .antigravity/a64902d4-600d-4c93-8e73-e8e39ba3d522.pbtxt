          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <div className=\"space-y-1.5\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <span className=\"font-bold text-slate-800 uppercase text-[11px] block text-primary\">1. Ph\303\242n chia Cohort Nh\303\263m X\303\243</span>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                <p>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                  T\341\273\211nh l\341\273\231 c\303\263 t\341\273\225ng s\341\273\221 45 x\303\243 tr\341\273\261c thu\341\273\231c, \304\221\306\260\341\273\243c nh\303\263m l\303\240m 3 ph\303\242n v\303\271ng \304\221\341\273\213a l\303\275 kh\303\241c nhau \304\221\341\273\203 \303\241p d\341\273\245ng t\341\273\267 l\341\273\207 ng\306\260\341\273\241ng m\341\273\245c ti\303\252u ph\303\271 h\341\273\243p. C\341\272\245p x\303\243 t\341\273\261 t\341\273\225ng h\341\273\243p d\341\273\257 li\341\273\207u t\341\272\241i g\341\273\221c \304\221\341\273\203 ban ch\341\273\211 \304\221\341\272\241o t\341\273\211nh r\303\240 so\303\241t ch\341\272\245n ch\341\273\211nh."
