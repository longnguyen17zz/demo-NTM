  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect } from \'react\';\nimport {\n  FileText,\n  HelpCircle,\n  X,\n  PlusCircle,\n  FolderPlus,\n  Compass,\n  FileCheck2,\n  AlertTriangle,\n  Award,\n  BookOpen\n} from \'lucide-react\';\nimport Sidebar from \'./components/Sidebar\';\nimport Header from \'./components/Header\';\nimport OverviewTab from \'./components/OverviewTab\';\nimport ReportTab from \'./components/ReportTab\';\nimport CriteriaTab from \'./components/CriteriaTab\';\nimport StatisticsTab from \'./components/StatisticsTab\';\nimport { CriterionRow, ReportMeta, NotificationItem } from \'./types\';\nimport {\n  INITIAL_CRITERIA_ROWS,\n  INITIAL_REPORT_META,\n  INITIAL_NOTIFICATIONS\n} from \'./mockData\';\n\nexport default function App() {\n  // Navigation states. Load \'reports\' first to show the exact screen requested\n  const [currentTab, setCurrentTab] = useState<\'overview\' | \'reports\' | \'criteria\' | \'statistics\'>(\'reports\');\n\n  // Core programmatic data states\n  const [reportData, setReportData] = useState<CriterionRow[]>([]);\n  const [reportMeta, setReportMeta] = useState<ReportMeta>(INITIAL_REPORT_META);\n  const [notifications, setNotifications] = useState<NotificationItem[]>(INITIAL_NOTIFICATIONS);\n\n  // General utility states\n  const [searchQuery, setSearchQuery] = useState(\'\');\n  const [showHelpModal, setShowHelpModal] = useState(false);\n  const [showNewReportModal, setShowNewReportModal] = useState(false);\n\n  // New report creation form states\n  const [newYear, setNewYear] = useState(\'2024\');\n  const [newDuration, setNewDuration] = useState(\'6 th\303\241ng \304\221\341\272\247u n\304\203m\');\n  const [newCode, setNewCode] = useState(\'05\');\n\n  // Loading persisted draft states from localStorage on initialization\n  useEffect(() => {\n    const persistedData = localStorage.getItem(\'Draft_NTM_Data\');\n    const persistedMeta = localStorage.getItem(\'Draft_NTM_Meta\');\n\n    if (persistedData) {\n      try {\n        setReportData(JSON.parse(persistedData));\n      } catch (e) {\n        setReportData(INITIAL_CRITERIA_ROWS);\n      }\n    } else {\n      setReportData(INITIAL_CRITERIA_ROWS);\n    }\n\n    if (persistedMeta) {\n      try {\n        setReportMeta(JSON.parse(persistedMeta));\n      } catch (e) {\n        setReportMeta(INITIAL_REPORT_META);\n      }\n    } else {\n      setReportMeta(INITIAL_REPORT_META);\n    }\n  }, []);\n\n  // Sync state changes back up to parents\n  const handleDataChange = (newData: CriterionRow[]) => {\n    setReportData(newData);\n    localStorage.setItem(\'Draft_NTM_Data\', JSON.stringify(newData));\n  };\n\n  const handleMetaChange = (newMeta: ReportMeta) => {\n    setReportMeta(newMeta);\n    localStorage.setItem(\'Draft_NTM_Meta\', JSON.stringify(newMeta));\n  };\n\n  // Notification action handlers\n  const handleMarkNotificationAsRead = (id: string) => {\n    setNotifications((prev) =>\n      prev.map((item) => (item.id === id ? { ...item, read: true } : item))\n    );\n  };\n\n  const handleClearAllNotifications = () => {\n    setNotifications((prev) => prev.map((item) => ({ ...item, read: true })));\n  };\n\n  // Handle building new dynamic report draft\n  const handleCreateNewReport = (e: React.FormEvent) => {\n    e.preventDefault();\n\n    // Reset rows to zero values as requested\n    const blankRows = INITIAL_CRITERIA_ROWS.map((row) => ({\n      ...row,\n      group1: { prevYear: 0, currentS1: 0, planS2: 0 },\n      group2: { prevYear: 0, currentS1: 0, planS2: 0 },\n      group3: { prevYear: 0, currentS1: 0, planS2: 0 },\n      note: \'\',\n    }));\n\n    const nextMeta: ReportMeta = {\n      title: `K\341\272\276T QU\341\272\242 TH\341\273\260C HI\341\273\206N B\341\273\230 TI\303\212U CH\303\215 QU\341\273\220C GIA V\341\273\200 N\303\224NG TH\303\224N M\341\273\232I ${newDuration.toUpperCase()} N\304\202M ${newYear}`,\n      subTitle: `(Kh\341\273\237i t\341\272\241o m\341\272\253u ki\341\273\203m t\341\273\261 c\341\272\245p t\341\273\211nh cho Bi\341\273\203u m\341\272\253u s\341\273\221 ${newCode} - K\303\250m theo Ch\306\260\306\241ng tr\303\254nh M\341\273\245c ti\303\252u n\303\264ng th\303\264n m\341\273\233i)`,\n      code: `BI\341\273\202U M\341\272\252U S\341\273\220 ${newCode}`,\n      status: \'UPDATING\',\n      deadline: `31/12/${newYear}`,\n      updatedAt: new Date().toISOString(),\n      editor: \'Nguy\341\273\205n V\304\203n An\',\n      role: \'C\303\241n b\341\273\231 T\341\273\211nh\',\n      proofFiles: [],\n    };\n\n    setReportData(blankRows);\n    setReportMeta(nextMeta);\n\n    localStorage.setItem(\'Draft_NTM_Data\', JSON.stringify(blankRows));\n    localStorage.setItem(\'Draft_NTM_Meta\', JSON.stringify(nextMeta));\n\n    setShowNewReportModal(false);\n    setCurrentTab(\'reports\');\n\n    // Notify user of draft creation success\n    alert(`\304\220\303\243 kh\341\273\237i t\341\272\241o bi\341\273\203u m\341\272\253u nh\341\272\255p s\341\273\221 ${newCode} cho n\304\203m k\341\272\277 ho\341\272\241ch ${newYear} th\303\240nh c\303\264ng!`);\n  };\n\n  // Filter criteria data when using global quick search\n  const filteredReportData = reportData.filter((row) =>\n    row.category.toLowerCase().includes(searchQuery.toLowerCase()) ||\n    row.note.toLowerCase().includes(searchQuery.toLowerCase())\n  );\n\n  return (\n    <div className=\"min-h-screen bg-surface-bg flex\">\n      {/* Sidebar navigation context */}\n      <Sidebar\n        currentTab={currentTab}\n        onTabChange={(tab) => {\n          setCurrentTab(tab);\n          window.scrollTo({ top: 0, behavior: \'smooth\' });\n        }}\n        onNewReportClick={() => setShowNewReportModal(true)}\n      />\n\n      {/* Primary content side screen wrapper */}\n      <div className=\"flex-1 pl-64 flex flex-col min-h-screen\">\n        <Header\n          notifications={notifications}\n          onMarkNotificationAsRead={handleMarkNotificationAsRead}\n          onClearAllNotifications={handleClearAllNotifications}\n          searchQuery={searchQuery}\n          onSearchChange={setSearchQuery}\n          onOpenHelpModal={() => setShowHelpModal(true)}\n        />\n\n        {/* Dynamic content rendering with quick transition animations */}\n        <main className=\"p-8 pt-24 max-w-7xl w-full mx-auto flex-1\">\n          {currentTab === \'overview\' && (\n            <OverviewTab onGoToReport={() => setCurrentTab(\'reports\')} />\n          )}\n\n          {currentTab === \'reports\' && (\n            <ReportTab\n              reportData={filteredReportData}\n              onDataChange={handleDataChange}\n              reportMeta={reportMeta}\n              onMetaChange={handleMetaChange}\n            />\n          )}\n\n          {currentTab === \'criteria\' && <CriteriaTab />}\n\n          {currentTab === \'statistics\' && <StatisticsTab reportData={reportData} />}\n        </main>\n      </div>\n\n      {/* Guide Manual Help Overlay Modal */}\n      {showHelpModal && (\n        <div className=\"fixed inset-0 bg-slate-950/45 backdrop-blur-sm flex items-center justify-center z-50 p-4\">\n          <div className=\"bg-white rounded-2xl max-w-2xl w-full p-7 shadow-2xl border border-slate-100 animate-fade-in\">\n            <div className=\"flex justify-between items-start mb-5 border-b border-slate-100 pb-3\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"p-2 bg-indigo-50 rounded-lg text-primary\">\n                  <HelpCircle className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"text-sm font-extrabold text-slate-800\">Quy t\341\272\257c Nghi\341\273\207p v\341\273\245 &amp; Y\303\252u c\341\272\247u K\341\273\271 thu\341\272\255t</h4>\n                  <p className=\"text-[10px] text-secondary font-medium\">C\341\273\225ng th\303\264ng tin h\306\260\341\273\233ng d\341\272\245n V\304\203n ph\303\262ng \304\220i\341\273\201u ph\341\273\221i NTM T\341\273\211nh</p>\n                </div>\n              </div>\n              <button\n                onClick={() => setShowHelpModal(false)}\n                className=\"text-secondary/50 hover:text-slate-800 p-1 rounded-lg transition-colors\"\n              >\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            <div className=\"space-y-4 max-h-96 overflow-y-auto pr-2 text-xs text-slate-600 leading-relaxed\">\n              <div className=\"space-y-1.5\">\n                <span className=\"font-bold text-slate-800 uppercase text-[11px] block text-primary\">1. Ph\303\242n chia Cohort Nh\303\263m X\303\243</span>\n                <p>\n                  T\341\273\211nh l\341\273\231 c\303\263 t\341\273\225ng s\341\273\221 45 x\303\243 tr\341\273\261c thu\341\273\231c, \304\221\306\260\341\273\243c nh\303\263m l\303\240m 3 ph\303\242n v\303\271ng \304\221\341\273\213a l\303\275 kh\303\241c nhau \304\221\341\273\203 \303\241p d\341\273\245ng t\341\273\267 l\341\273\207 ng\306\260\341\273\241ng m\341\273\245c ti\303\252u ph\303\271 h\341\273\243p. C\341\272\245p x\303\243 t\341\273\261 t\341\273\225ng h\341\273\243p d\341\273\257 li\341\273\207u t\341\272\241i g\341\273\221c \304\221\341\273\203 ban ch\341\273\211 \304\221\341\272\241o t\341\273\211nh r\303\240 so\303\241t ch\341\272\245n ch\341\273\211nh.\n                </p>\n              </div>\n\n              <div className=\"space-y-1.5\">\n                <span className=\"font-bold text-slate-800 uppercase text-[11px] block text-primary\">2. C\306\241 ch\341\272\277 t\341\273\261 \304\221\341\273\231ng b\303\271 l\341\272\245p \"K\341\272\277 ho\341\272\241ch 6 th\303\241ng cu\341\273\221i n\304\203m\"</span>\n                <p>\n                  Ch\341\273\211 ti\303\252u cu\341\273\221i n\304\203m do c\303\241c ph\303\262ng ban ch\341\273\251c n\304\203ng ho\341\272\241ch \304\221\341\273\213nh. C\303\241c \303\264 nh\341\272\255p li\341\273\207u c\303\263 m\303\240u \303\241nh xanh nh\341\272\271 bi\341\273\203u tr\306\260ng cho c\303\241c c\341\273\231t d\341\273\257 li\341\273\207u li\303\252n quan m\341\272\255t thi\341\272\277t \304\221\341\272\277n ti\341\272\277n \304\221\341\273\231 gi\341\272\243i ng\303\242n x\303\242y d\341\273\261ng c\306\241 b\341\272\243n.\n                </p>\n              </div>\n\n              <div className=\"space-y-1.5\">\n                <span className=\"font-bold text-slate-800 uppercase text-[11px] block text-primary\">3. Quy chu\341\272\251n ch\341\273\257 k\303\275 s\341\273\221 CA qu\341\273\221c gia</span>\n                <p>\n                  H\341\273\223 s\306\241 g\341\273\255i l\303\252n b\341\273\231 ng\303\240nh trung \306\260\306\241ng b\341\272\257t bu\341\273\231c \304\221\306\260\341\273\243c ch\341\273\251ng th\341\273\261c ph\303\252 chu\341\272\251n th\303\264ng qua h\341\273\207 th\341\273\221ng ch\341\273\251ng th\306\260 s\341\273\221 c\341\273\247a T\341\273\225ng c\341\273\245c B\306\260u \304\221i\341\273\207n ho\341\272\267c ban c\306\241 y\341\272\277u Ch\303\255nh ph\341\273\247. Vi\341\273\207c nh\341\272\255p H\341\273\215 v\303\240 T\303\252n ng\306\260\341\273\235i k\303\275 \341\273\237 b\341\272\243ng x\303\241c th\341\273\261c \304\221\303\263ng vai tr\303\262 kh\341\273\237i \304\221\341\273\231ng m\303\264-\304\221un sinh kh\303\263a PKCS#11 x\303\241c th\341\273\261c d\341\273\257 li\341\273\207u.\n                </p>\n              </div>\n            </div>\n\n            <div className=\"mt-6 flex justify-end\">\n              <button\n                onClick={() => setShowHelpModal(false)}\n                className=\"px-5 py-2.5 bg-primary text-white text-xs font-bold rounded-lg hover:bg-primary-container transition-all\"\n              >\n                \304\220\303\243 hi\341\273\203u quy t\341\272\257c\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* New Report Initiation Overlay Modal */}\n      {showNewReportModal && (\n        <div className=\"fixed inset-0 bg-slate-950/45 backdrop-blur-sm flex items-center justify-center z-50 p-4\">\n          <div className=\"bg-white rounded-2xl max-w-md w-full p-6 shadow-2xl border border-slate-100 animate-slide-up\">\n            <div className=\"flex justify-between items-start mb-5\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"p-2 bg-emerald-50 text-emerald-600 rounded-lg\">\n                  <FolderPlus className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"text-sm font-extrabold text-slate-900\">Kh\341\273\237i t\341\272\241o \304\221\341\273\243t b\303\241o c\303\241o m\341\273\233i</h4>\n                  <p className=\"text-[10px] text-secondary font-medium\">T\341\272\241o ph\303\241c th\341\272\243o bi\341\273\203u m\341\272\253u tr\341\273\221ng \304\221\341\273\203 nh\341\272\255p li\341\273\207u</p>\n                </div>\n              </div>\n              <button\n                onClick={() => setShowNewReportModal(false)}\n                className=\"text-secondary/60 hover:text-slate-800\"\n              >\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            <form onSubmit={handleCreateNewReport} className=\"space-y-4\">\n              {/* Report Year Input Option */}\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1\">N\304\203m b\303\241o c\303\241o k\341\272\277 ho\341\272\241ch</label>\n                <select\n                  value={newYear}\n                  onChange={(e) => setNewYear(e.target.value)}\n                  className=\"w-full text-xs p-2.5 duration-200 border border-slate-300 rounded-lg outline-none focus:ring-2 focus:ring-primary/25 bg-slate-50 font-medium\"\n                >\n                  <option value=\"2024\">N\304\203m 2024</option>\n                  <option value=\"2025\">N\304\203m 2025</option>\n                  <option value=\"2026\">N\304\203m 2026 (K\341\273\263 t\341\273\233i)</option>\n                </select>\n              </div>\n\n              {/* Report Duration Parameter */}\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1\">K\341\273\263 b\303\241o c\303\241o ti\341\272\277n \304\221\341\273\231</label>\n                <select\n                  value={newDuration}\n                  onChange={(e) => setNewDuration(e.target.value)}\n                  className=\"w-full text-xs p-2.5 duration-200 border border-slate-300 rounded-lg outline-none focus:ring-2 focus:ring-primary/25 bg-slate-50 font-medium\"\n                >\n                  <option value=\"6 th\303\241ng \304\221\341\272\247u n\304\203m\">6 Th\303\241ng \304\221\341\272\247u n\304\203m</option>\n                  <option value=\"6 th\303\241ng cu\341\273\221i n\304\203m\">6 Th\303\241ng cu\341\273\221i n\304\203m</option>\n                  <option value=\"C\341\272\243 n\304\203m\">To\303\240n di\341\273\207n c\341\272\243 n\304\203m</option>\n                </select>\n              </div>\n\n              {/* Template identifier */}\n              <div>\n                <label className=\"text-xs font-bold text-slate-700 block mb-1\">Thi\341\272\277t k\341\272\277 m\341\272\253u ph\303\241c th\341\272\243o h\303\240nh ch\303\255nh</label>\n                <select\n                  value={newCode}\n                  onChange={(e) => setNewCode(e.target.value)}\n                  className=\"w-full text-xs p-2.5 duration-200 border border-slate-300 rounded-lg outline-none focus:ring-2 focus:ring-primary/25 bg-slate-50 font-medium\"\n                >\n                  <option value=\"05\">Bi\341\273\203u m\341\272\253u s\341\273\221 05 (Qu\341\273\221c gia)</option>\n                  <option value=\"03\">Bi\341\273\203u m\341\272\253u s\341\273\221 03 (Li\303\252n ng\303\240nh)</option>\n                  <option value=\"01\">Bi\341\273\203u m\341\272\253u s\341\273\221 01 (C\341\272\245p x\303\243 t\341\273\261 khai)</option>\n                </select>\n              </div>\n\n              <div className=\"bg-yellow-50/70 p-3 rounded-lg border border-yellow-200/50 flex gap-2\">\n                <AlertTriangle className=\"w-4.5 h-4.5 text-status-pending shrink-0 mt-0.5\" />\n                <p className=\"text-[10px] text-secondary leading-normal\">\n                  Ch\303\272 \303\275: Vi\341\273\207c kh\341\273\237i t\341\272\241o \304\221\341\273\243t b\303\241o c\303\241o m\341\273\233i s\341\272\275 l\303\240m tr\341\273\221ng to\303\240n b\341\273\231 d\341\273\257 li\341\273\207u hi\341\273\207n t\341\272\241i trong \303\264 \304\221\341\273\203 chu\341\272\251n b\341\273\213 \304\221\341\273\243t b\303\241o c\303\241o k\341\272\277 ho\341\272\241ch s\341\272\241ch. H\303\243y \304\221\341\272\243m b\341\272\243o b\341\272\241n \304\221\303\243 l\306\260u ho\341\272\267c g\341\273\255i \304\221\341\273\243t hi\341\273\207n t\341\272\241i.\n                </p>\n              </div>\n\n              <div className=\"flex gap-3 pt-2\">\n                <button\n                  type=\"button\"\n                  onClick={() => setShowNewReportModal(false)}\n                  className=\"flex-1 py-2.5 border border-slate-300 text-slate-600 text-xs font-bold rounded-lg hover:bg-slate-50\"\n                >\n                  H\341\273\247y b\341\273\217\n                </button>\n                <button\n                  type=\"submit\"\n                  className=\"flex-1 py-2.5 bg-primary hover:bg-primary-container text-white text-xs font-bold rounded-lg flex items-center justify-center gap-1.5 shadow-md shadow-primary/15\"\n                >\n                  <PlusCircle className=\"w-4 h-4\" />\n                  <span>T\341\272\241o ph\303\241c th\341\272\243o</span>\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
    }
