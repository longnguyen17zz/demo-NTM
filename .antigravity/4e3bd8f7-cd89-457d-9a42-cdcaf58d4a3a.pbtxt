3\241ng 05\", group1: 15, group2: 9, group3: 5 }\n];\n\nexport const CRITERIA_COMPLETION_PIE = [\n  { name: \"\304\220\341\272\241t ti\303\252u ch\303\255\", value: 28, color: \"#10B981\" },\n  { name: \"C\341\272\255n \304\221\341\272\241t (80-99%)\", value: 12, color: \"#3B82F6\" },\n  { name: \"Ch\306\260a \304\221\341\272\241t (<80%)\", value: 5, color: \"#F59E0B\" }\n];\n\nexport const DETAILED_METRIC_DESCRIPTIONS = [\n  {\n    id: 1,\n    title: \"Ti\303\252u ch\303\255 1: Quy ho\341\272\241ch\",\n    description: \"Y\303\252u c\341\272\247u c\303\263 quy ho\341\272\241ch chung x\303\242y d\341\273\261ng x\303\243 \304\221\306\260\341\273\243c ph\303\252 duy\341\273\207t ph\303\271 h\341\273\243p v\341\273\233i quy ho\341\272\241ch v\303\271ng huy\341\273\207n v\303\240 \304\221\306\260\341\273\243c c\303\264ng b\341\273\221 c\303\264ng khai. \304\220\341\272\241t y\303\252u c\341\272\247u v\341\273\201 qu\341\272\243n l\303\275 x\303\242y d\341\273\261ng theo quy ho\341\272\241ch.\",\n    indicator: \"C\303\263 ban qu\341\272\243n l\303\275 v\303\240 quy \304\221\341\273\213nh qu\341\272\243n l\303\275 quy ho\341\272\241ch \304\221\303\272ng ph\303\241p lu\341\272\255t.\",\n    weight: \"10%\"\n  },\n  {\n    id: 2,\n    title: \"Ti\303\252u ch\303\255 2: Giao th\303\264ng & H\341\272\241 t\341\272\247ng k\341\273\271 thu\341\272\255t\",\n    description: \"\304\220\306\260\341\273\235ng x\303\243 v\303\240 \304\221\306\260\341\273\235ng trung t\303\242m x\303\243 \304\221\341\272\277n \304\221\306\260\341\273\235ng huy\341\273\207n \304\221\306\260\341\273\243c nh\341\273\261a h\303\263a ho\341\272\267c b\303\252 t\303\264ng h\303\263a, b\341\272\243o \304\221\341\272\243m \303\264 t\303\264 \304\221i l\341\272\241i thu\341\272\255n ti\341\273\207n quanh n\304\203m.\",\n    indicator: \"T\341\273\267 l\341\273\207 km \304\221\306\260\341\273\235ng tr\341\273\245c th\303\264n, b\341\272\243n \304\221\306\260\341\273\243c c\341\273\251ng h\303\263a \304\221\341\272\241t chu\341\272\251n t\341\273\221i thi\341\273\203u 70% tr\341\273\237 l\303\252n.\",\n    weight: \"15%\"\n  },\n  {\n    id: 3,\n    title: \"Ti\303\252u ch\303\255 3: Th\341\273\247y l\341\273\243i v\303\240 Ph\303\262ng ch\341\273\221ng thi\303\252n tai\",\n    description: \"H\341\273\207 th\341\273\221ng th\341\273\247y l\341\273\243i b\341\272\243o \304\221\341\272\243m ch\341\273\247 \304\221\341\273\231ng t\306\260\341\273\233i, ti\303\252u cho di\341\273\207n t\303\255ch \304\221\341\272\245t s\341\272\243n xu\341\272\245t n\303\264ng nghi\341\273\207p \304\221\341\272\241t chu\341\272\251n t\341\273\253 80% tr\341\273\237 l\303\252n.\",\n    indicator: \"C\303\263 c\303\241c t\341\273\225 ch\341\273\251c h\341\273\243p t\303\241c x\303\243 d\303\271ng n\306\260\341\273\233c ho\341\272\241t \304\221\341\273\231ng b\341\273\201n v\341\273\257ng.\",\n    weight: \"8%\"\n  },\n  {\n    id: 4,\n    title: \"Ti\303\252u ch\303\255 4: \304\220i\341\273\207n n\303\264ng th\303\264n\",\n    description: \"H\341\273\207 th\341\273\221ng \304\221i\341\273\207n \304\221\341\272\241t chu\341\272\251n k\341\273\271 thu\341\272\255t c\341\273\247a ng\303\240nh \304\221i\341\273\207n. T\341\273\267 l\341\273\207 h\341\273\231 s\341\273\255 d\341\273\245ng \304\221i\341\273\207n th\306\260\341\273\235ng xuy\303\252n, an to\303\240n t\341\273\253 c\303\241c ngu\341\273\223n \304\221\341\272\241t t\341\273\253 98% tr\341\273\237 l\303\252n.\",\n    indicator: \"Ngu\341\273\223n cung c\341\272\245p \304\221i\341\273\207n \341\273\225n \304\221\341\273\213nh, h\341\272\241 t\341\272\247ng \304\221i\341\273\207n n\303\264ng th\303\264n \304\221\341\272\243m b\341\272\243o ph\303\262ng ch\341\273\221ng ch\303\241y n\341\273\225.\",\n    weight: \"5%\"\n  },\n  {\n    id: 5,\n    title: \"Ti\303\252u ch\303\255 5: Gi\303\241o d\341\273\245c & \304\220\303\240o t\341\272\241o ngh\341\273\201\",\n    description: \"Nh\303\240 tr\306\260\341\273\235ng c\303\241c c\341\272\245p c\303\263 c\306\241 s\341\273\237 v\341\272\255t ch\341\272\245t v\303\240 thi\341\272\277t b\341\273\213 d\341\272\241y h\341\273\215c \304\221\341\272\241t chu\341\272\251n qu\341\273\221c gia. \304\220\341\272\241t chu\341\272\251n x\303\263a m\303\271 ch\341\273\257 v\303\240 ph\341\273\225 c\341\272\255p gi\303\241o d\341\273\245c c\341\272\245p trung h\341\273\215c c\306\241 s\341\273\237.\",\n    indicator: \"T\341\273\267 l\341\273\207 h\341\273\215c sinh t\341\273\221t nghi\341\273\207p THCS ti\341\272\277p t\341\273\245c \304\221i h\341\273\215c trung h\341\273\215c ho\341\272\267c h\341\273\215c ngh\341\273\201 t\341\273\221i thi\341\273\203u \304\221\341\272\241t 75%.\",\n    weight: \"12%\"\n  },\n  {\n    id: 6,\n    title: \"Ti\303\252u ch\303\255 6: C\306\241 s\341\273\237 v\341\272\255t ch\341\272\245t V\304\203n h\303\263a\",\n    description: \"X\303\243 c\303\263 nh\303\240 v\304\203n h\303\263a ho\341\272\267c h\341\273\231i tr\306\260\341\273\235ng \304\221a n\304\203ng c\303\263 quy m\303\264 ch\341\273\227 ng\341\273\223i \304\221\341\272\241t chu\341\272\251n, c\303\263 s\303\242n th\341\273\203 thao ph\341\273\245c v\341\273\245 c\341\273\231ng \304\221\341\273\223ng.\",\n    indicator: \"T\341\273\267 l\341\273\207 th\303\264n, b\341\272\243n c\303\263 khu th\341\273\203 thao, nh\303\240 v\304\203n h\303\263a \304\221\341\272\241t chu\341\272\251n t\341\273\221i thi\341\273\203u t\341\273\253 70% tr\341\273\237 l\303\252n.\",\n    weight: \"5%\"\n  },\n  {\n    id: 7,\n    title: \"Ti\303\252u ch\303\255 7: C\306\241 s\341\273\237 h\341\272\241 t\341\272\247ng th\306\260\306\241ng m\341\272\241i n\303\264ng th\303\264n\",\n    description: \"X\303\243 c\303\263 ch\341\273\243 n\303\264ng th\303\264n ho\341\272\267c si\303\252u th\341\273\213 mini x\303\242y d\341\273\261ng \304\221\303\272ng quy chu\341\272\251n qu\341\273\221c gia, ban qu\341\272\243n l\303\275 ho\341\272\241t \304\221\341\273\231ng hi\341\273\207u qu\341\272\243.\",\n    indicator: \"C\303\263 khu v\341\273\261c v\341\273\207 sinh c\303\264ng c\341\273\231ng, \304\221\341\272\243m b\341\272\243o v\341\273\207 sinh an to\303\240n th\341\273\261c ph\341\272\251m.\",\n    weight: \"5%\"\n  },\n  {\n    id: 8,\n    title: \"Ti\303\252u ch\303\255 8: Th\303\264ng tin v\303\240 Truy\341\273\201n th\303\264ng\",\n    description: \"X\303\243 c\303\263 \304\221i\341\273\203m ph\341\273\245c v\341\273\245 b\306\260u ch\303\255nh vi\341\273\205n th\303\264ng c\303\263 Internet t\341\273\221c \304\221\341\273\231 cao. C\303\263 \304\221\303\240i truy\341\273\201n thanh ph\303\241t thanh \304\221\341\272\277n to\303\240n b\341\273\231 c\303\241c khu d\303\242n c\306\260.\",\n    indicator: \"C\303\263 \341\273\251ng d\341\273\245ng c\303\264ng ngh\341\273\207 th\303\264ng tin trong gi\341\272\243i quy\341\272\277t d\341\273\213ch v\341\273\245 c\303\264ng c\341\272\245p x\303\243.\",\n    weight: \"10%\"\n  },\n  {\n    id: 9,\n    title: \"Ti\303\252u ch\303\255 9: Nh\303\240 \341\273\237 d\303\242n c\306\260 n\303\264ng th\303\264n\",\n    description: \"Kh\303\264ng c\303\262n nh\303\240 t\341\272\241m, nh\303\240 d\341\273\231t n\303\241t tr\303\252n \304\221\341\273\213a b\303\240n x\303\243. T\341\273\267 l\341\273\207 h\341\273\231 gia \304\221\303\254nh c\303\263 nh\303\240 \341\273\237 ki\303\252n c\341\273\221 ho\341\272\267c b\303\241n ki\303\252n c\341\273\221 \304\221\341\272\241t t\341\273\253 90% tr\341\273\237 l\303\252n.\",\n    indicator: \"Di\341\273\207n t\303\255ch nh\303\240 \341\273\237 b\303\254nh qu\303\242n \304\221\341\272\247u ng\306\260\341\273\235i \304\221\341\272\241t m\341\273\251c t\341\273\221i thi\341\273\203u 15-20 m2/ng\306\260\341\273\235i.\",\n    weight: \"15%\"\n  },\n  {\n    id: 10,\n    title: \"Ti\303\252u ch\303\255 10: Thu nh\341\272\255p & Ph\303\241t tri\341\273\203n kinh t\341\272\277\",\n    description: \"M\341\273\251c thu nh\341\272\255p b\303\254nh qu\303\242n \304\221\341\272\247u ng\306\260\341\273\235i c\341\273\247a x\303\243 \304\221\341\272\241t t\341\273\221i thi\341\273\203u t\341\273\253 53 tri\341\273\207u \304\221\341\273\223ng/ng\306\260\341\273\235i/n\304\203m tr\341\273\237 l\303\252n (\304\221i\341\273\201u ch\341\273\211nh t\304\203ng theo t\341\273\253ng n\304\203m v\303\240 t\341\273\253ng v\303\271ng c\341\273\245 th\341\273\203).\",\n    indicator: \"C\303\263 c\303\241c chu\341\273\227i m\303\264 h\303\254nh li\303\252n k\341\272\277t s\341\272\243n xu\341\272\245t n\303\264ng nghi\341\273\207p \341\273\251ng d\341\273\245ng c\303\264ng ngh\341\273\207 cao.\",\n    weight: \"15%\"\n  }\n];\n"
    }
